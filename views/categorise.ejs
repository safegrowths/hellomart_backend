<%- include('layout/header', { title: 'Categories List', showNavigation: true }) %>
<%- include('layout/sidebar', { currentPage: 'categories-list' }) %>

<!-- Main Content Area -->
<div class="main-content" style="margin-left: 250px; padding: 20px; background: #f8f9fa; min-height: 100vh;">
  <div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0 text-gray-800">Categories Management</h1>
      <button type="button" class="btn btn-primary" id="addCategoryBtn">
        <i class="fas fa-plus"></i> Add New Category
      </button>
    </div>

    <!-- Categories Card -->
    <div class="card shadow">
      <div class="card-header bg-white py-3">
        <ul class="nav nav-tabs card-header-tabs" id="categoryTabs" role="tablist">
          <li class="nav-item">
            <button class="nav-link active" id="active-tab" data-bs-toggle="tab" 
                    data-bs-target="#active" type="button" role="tab">
              Active Categories
              <span class="badge bg-success ms-1" id="activeCount">0</span>
            </button>
          </li>
          <li class="nav-item">
            <button class="nav-link" id="inactive-tab" data-bs-toggle="tab" 
                    data-bs-target="#inactive" type="button" role="tab">
              Inactive Categories
              <span class="badge bg-secondary ms-1" id="inactiveCount">0</span>
            </button>
          </li>
        </ul>
      </div>
      <div class="card-body">
        <div class="tab-content" id="categoryTabsContent">
          <!-- Active Categories Tab -->
          <div class="tab-pane fade show active" id="active" role="tabpanel">
            <div class="table-responsive">
              <table class="table table-hover table-bordered">
                <thead class="table-light">
                  32<
                    <th width="5%">ID</th>
                    <th width="25%">Category Name</th>
                    <th width="20%">Slug</th>
                    <th width="10%">Status</th>
                    <th width="20%">Created Date</th>
                    <th width="20%">Actions</th>
                  </tr>
                </thead>
                <tbody id="activeCategoriesList">
                  <tr>
                    <td colspan="6" class="text-center text-muted py-4">No active categories found</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Inactive Categories Tab -->
          <div class="tab-pane fade" id="inactive" role="tabpanel">
            <div class="table-responsive">
              <table class="table table-hover table-bordered">
                <thead class="table-light">
                  <tr>
                    <th width="5%">ID</th>
                    <th width="25%">Category Name</th>
                    <th width="20%">Slug</th>
                    <th width="10%">Status</th>
                    <th width="20%">Created Date</th>
                    <th width="20%">Actions</th>
                  </tr>
                </thead>
                <tbody id="inactiveCategoriesList">
                  <tr>
                    <td colspan="6" class="text-center text-muted py-4">No inactive categories found</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal for Add/Edit Category -->
<div class="modal fade" id="categoryModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="categoryModalLabel">Add New Category</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="categoryForm">
          <div class="mb-3">
            <label for="categoryName" class="form-label fw-bold">Category Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="categoryName" required 
                   placeholder="Enter category name">
          </div>
          <div class="mb-3">
            <label for="categorySlug" class="form-label fw-bold">Slug</label>
            <input type="text" class="form-control" id="categorySlug" 
                   placeholder="auto-generated from name">
            <small class="text-muted">Leave empty to auto-generate</small>
          </div>
          <div class="mb-3">
            <label for="categoryStatus" class="form-label fw-bold">Status</label>
            <select class="form-select" id="categoryStatus">
              <option value="active">Active</option>
              <option value="inactive">Inactive</option>
            </select>
          </div>
          <div class="mb-3">
            <label for="categoryDescription" class="form-label fw-bold">Description</label>
            <textarea class="form-control" id="categoryDescription" rows="3" 
                      placeholder="Category description (optional)"></textarea>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="saveCategoryBtn">Save Category</button>
      </div>
    </div>
  </div>
</div>

<style>
.main-content {
  margin-left: 250px;
  padding: 20px;
  background: #f8f9fa;
  min-height: 100vh;
}

.card {
  border: none;
  border-radius: 10px;
}

.card-header {
  border-bottom: 1px solid #e3e6f0;
  background: white;
}

.table th {
  font-weight: 600;
  color: #4e73df;
  border-bottom-width: 1px;
}

.btn-sm {
  margin: 0 2px;
  padding: 5px 10px;
}

.badge {
  font-size: 12px;
  padding: 5px 8px;
}

@media (max-width: 768px) {
  .main-content {
    margin-left: 0;
    padding: 15px;
  }
}
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
$(document).ready(function() {
    // 10 DEMO CATEGORIES DATA
    let categories = [
        {
            id: 1,
            name: "Electronics",
            slug: "electronics",
            status: "active",
            description: "All electronic products including smartphones, laptops, tablets, and accessories",
            createdDate: new Date(2024, 0, 10)
        },
        {
            id: 2,
            name: "Clothing",
            slug: "clothing",
            status: "active",
            description: "Fashion apparel for men, women, and children",
            createdDate: new Date(2024, 0, 12)
        },
        {
            id: 3,
            name: "Books",
            slug: "books",
            status: "active",
            description: "Fiction, non-fiction, educational, and reference books",
            createdDate: new Date(2024, 0, 15)
        },
        {
            id: 4,
            name: "Home & Garden",
            slug: "home-garden",
            status: "inactive",
            description: "Furniture, decor, gardening tools, and outdoor equipment",
            createdDate: new Date(2024, 0, 18)
        },
        {
            id: 5,
            name: "Sports",
            slug: "sports",
            status: "active",
            description: "Sports equipment, fitness gear, and outdoor sports items",
            createdDate: new Date(2024, 0, 20)
        },
        {
            id: 6,
            name: "Toys & Games",
            slug: "toys-games",
            status: "active",
            description: "Educational toys, board games, and kids entertainment",
            createdDate: new Date(2024, 1, 1)
        },
        {
            id: 7,
            name: "Beauty & Health",
            slug: "beauty-health",
            status: "inactive",
            description: "Cosmetics, skincare, healthcare products, and wellness items",
            createdDate: new Date(2024, 1, 5)
        },
        {
            id: 8,
            name: "Automotive",
            slug: "automotive",
            status: "active",
            description: "Car accessories, tools, and automotive parts",
            createdDate: new Date(2024, 1, 8)
        },
        {
            id: 9,
            name: "Food & Beverages",
            slug: "food-beverages",
            status: "inactive",
            description: "Groceries, snacks, beverages, and gourmet foods",
            createdDate: new Date(2024, 1, 12)
        },
        {
            id: 10,
            name: "Furniture",
            slug: "furniture",
            status: "active",
            description: "Home and office furniture, sofas, tables, and chairs",
            createdDate: new Date(2024, 1, 15)
        }
    ];
    
    let editingId = null;

    // Generate slug
    function generateSlug(name) {
        return name.toLowerCase()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-+|-+$/g, '');
    }

    // Auto-generate slug from name
    $('#categoryName').on('input', function() {
        const slugInput = $('#categorySlug');
        if (!slugInput.val() || slugInput.val() === generateSlug(this.value)) {
            slugInput.val(generateSlug(this.value));
        }
    });

    // Render categories
    function renderCategories() {
        const activeCategories = categories.filter(cat => cat.status === 'active');
        const inactiveCategories = categories.filter(cat => cat.status === 'inactive');
        
        $('#activeCount').text(activeCategories.length);
        $('#inactiveCount').text(inactiveCategories.length);
        
        // Active categories
        const activeList = $('#activeCategoriesList');
        if (activeCategories.length === 0) {
            activeList.html('<tr><td colspan="6" class="text-center text-muted py-4">No active categories found</td></tr>');
        } else {
            activeList.html(activeCategories.map(cat => `
                <tr>
                    <td>${cat.id}</td>
                    <td><strong>${escapeHtml(cat.name)}</strong><br><small class="text-muted">${escapeHtml(cat.description || 'No description')}</small></td>
                    <td><code>${escapeHtml(cat.slug)}</code></td>
                    <td><span class="badge bg-success">Active</span></td>
                    <td>${formatDate(cat.createdDate)}</td>
                    <td>
                        <button class="btn btn-sm btn-info" onclick="editCategory(${cat.id})">
                            <i class="fas fa-edit"></i> Edit
                        </button>
                        <button class="btn btn-sm btn-warning" onclick="toggleStatus(${cat.id})">
                            <i class="fas fa-ban"></i> Deactivate
                        </button>
                        <button class="btn btn-sm btn-danger" onclick="deleteCategory(${cat.id})">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </td>
                </tr>
            `).join(''));
        }
        
        // Inactive categories
        const inactiveList = $('#inactiveCategoriesList');
        if (inactiveCategories.length === 0) {
            inactiveList.html('<tr><td colspan="6" class="text-center text-muted py-4">No inactive categories found</td></tr>');
        } else {
            inactiveList.html(inactiveCategories.map(cat => `
                <tr>
                    <td>${cat.id}</td>
                    <td><strong>${escapeHtml(cat.name)}</strong><br><small class="text-muted">${escapeHtml(cat.description || 'No description')}</small></td>
                    <td><code>${escapeHtml(cat.slug)}</code></td>
                    <td><span class="badge bg-secondary">Inactive</span></td>
                    <td>${formatDate(cat.createdDate)}</td>
                    <td>
                        <button class="btn btn-sm btn-info" onclick="editCategory(${cat.id})">
                            <i class="fas fa-edit"></i> Edit
                        </button>
                        <button class="btn btn-sm btn-success" onclick="toggleStatus(${cat.id})">
                            <i class="fas fa-check"></i> Activate
                        </button>
                        <button class="btn btn-sm btn-danger" onclick="deleteCategory(${cat.id})">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </td>
                </tr>
            `).join(''));
        }
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    function formatDate(date) {
        return new Date(date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric'
        });
    }

    // CRUD Operations
    window.addCategory = function(categoryData) {
        const newId = categories.length > 0 ? Math.max(...categories.map(c => c.id)) + 1 : 1;
        const newCategory = {
            id: newId,
            ...categoryData,
            createdDate: new Date()
        };
        categories.push(newCategory);
        renderCategories();
        alert('Category added successfully');
    }

    window.updateCategory = function(id, categoryData) {
        const index = categories.findIndex(cat => cat.id === id);
        if (index !== -1) {
            categories[index] = { ...categories[index], ...categoryData };
            renderCategories();
            alert('Category updated successfully');
        }
    }

    window.deleteCategory = function(id) {
        if (confirm('Are you sure you want to delete this category?')) {
            categories = categories.filter(cat => cat.id !== id);
            renderCategories();
            alert('Category deleted successfully');
        }
    }

    window.toggleStatus = function(id) {
        const category = categories.find(cat => cat.id === id);
        if (category) {
            category.status = category.status === 'active' ? 'inactive' : 'active';
            renderCategories();
            alert(`Category ${category.status === 'active' ? 'activated' : 'deactivated'} successfully`);
        }
    }

    window.editCategory = function(id) {
        const category = categories.find(cat => cat.id === id);
        if (category) {
            editingId = id;
            $('#categoryModalLabel').text('Edit Category');
            $('#categoryName').val(category.name);
            $('#categorySlug').val(category.slug);
            $('#categoryStatus').val(category.status);
            $('#categoryDescription').val(category.description || '');
            $('#categoryModal').modal('show');
        }
    }

    // Event Listeners
    $('#addCategoryBtn').click(function() {
        editingId = null;
        $('#categoryModalLabel').text('Add New Category');
        $('#categoryForm')[0].reset();
        $('#categoryModal').modal('show');
    });

    $('#saveCategoryBtn').click(function() {
        const name = $('#categoryName').val().trim();
        if (!name) {
            alert('Please enter category name');
            return;
        }
        
        let slug = $('#categorySlug').val().trim();
        if (!slug) {
            slug = generateSlug(name);
        }
        
        const categoryData = {
            name: name,
            slug: slug,
            status: $('#categoryStatus').val(),
            description: $('#categoryDescription').val()
        };
        
        if (editingId) {
            updateCategory(editingId, categoryData);
        } else {
            addCategory(categoryData);
        }
        
        $('#categoryModal').modal('hide');
        $('#categoryForm')[0].reset();
    });

    // Initial render
    renderCategories();
});
</script>

<%- include('layout/footer', { pageScript: 'categories-init.min.js' }) %>
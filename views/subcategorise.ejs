<%- include('layout/header', { title: 'Subcategories List', showNavigation: true }) %>
<%- include('layout/sidebar', { currentPage: 'subcategories-list' }) %>

<div class="main-content">
  <div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3 class="fw-bold">Subcategories Management</h3>

      <div class="d-flex gap-2">
        <form method="GET" action="/subcategories" class="d-flex">
          <input type="text" name="search" value="<%= search %>" 
            class="form-control me-2" placeholder="Search...">
          <button class="btn btn-primary">Search</button>
        </form>

        <button class="btn btn-primary px-4" onclick="openModal()">
          <i class="fa fa-plus"></i> Add
        </button>
      </div>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm">
      <div class="card-body p-3">

        <div class="table-responsive">
          <table class="table table-hover align-middle">

            <thead class="table-light">
              <tr>
                <th>#</th>
                <th>Image</th>
                <th>Category</th>
                <th>Name</th>
                <th>Status</th>
                <th>Date</th>
                <th class="text-center">Actions</th>
              </tr>
            </thead>

            <tbody>
              <% if (subcategories.length === 0) { %>
                <tr>
                  <td colspan="7" class="text-center text-muted">No Data Found</td>
                </tr>
              <% } %>

              <% subcategories.forEach((sub, index) => { %>
                <tr>

                  <td><%= ((currentPage - 1) * 10) + index + 1 %></td>

                  <!-- IMAGE -->
                  <td>
                    <img 
                      src="<%= sub.image && sub.image.startsWith('http') 
                            ? sub.image 
                            : '/uploads/' + (sub.image || 'default.png') %>" 
                      width="50" height="50"
                      style="border-radius:50%;object-fit:cover;">
                  </td>

                  <td>
                    <span class="badge bg-info text-dark">
                      <%= sub.category_name || 'N/A' %>
                    </span>
                  </td>

                  <td class="fw-semibold"><%= sub.title %></td>

                  <td>
                    <% if (sub.status == 1) { %>
                      <span class="badge bg-success">Active</span>
                    <% } else { %>
                      <span class="badge bg-secondary">Inactive</span>
                    <% } %>
                  </td>

                  <td>
                    <%= new Date(sub.created_at).toLocaleDateString() %>
                  </td>

                  <td class="text-center">

                    <!-- EDIT -->
                    <button class="btn btn-sm btn-info text-white me-1"
                      onclick="editData(
                        <%= sub.id %>,
                        '<%= sub.title %>',
                        <%= sub.categorise_id %>,
                        <%= sub.status %>,
                        `<%= sub.description || '' %>`
                      )">
                      <i class="fa fa-edit"></i>
                    </button>

                    <!-- TOGGLE -->
                    <a href="/subcategories_status/<%= sub.id %>" 
                       class="btn btn-sm btn-warning me-1">
                       <i class="fa fa-sync"></i>
                    </a>

                    <!-- DELETE -->
                    <a href="/subcategories_delete/<%= sub.id %>" 
                       onclick="return confirm('Delete?')" 
                       class="btn btn-sm btn-danger">
                       <i class="fa fa-trash"></i>
                    </a>

                  </td>

                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- PAGINATION -->
        <div class="d-flex justify-content-center mt-3 flex-wrap">
          <% for(let i = 1; i <= totalPages; i++) { %>
            <a href="/subcategories?page=<%= i %>&search=<%= search %>"
              class="btn btn-sm <%= i==currentPage ? 'btn-primary':'btn-outline-primary' %> m-1">
              <%= i %>
            </a>
          <% } %>
        </div>

      </div>
    </div>

  </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="myModal">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title" id="modalTitle">Add Subcategory</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <form id="form">

          <input type="hidden" id="id">

          <select id="category" class="form-control mb-2">
            <option value="">Select Category</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>"><%= cat.title %></option>
            <% }) %>
          </select>

          <input type="text" id="title" class="form-control mb-2" placeholder="Name">

          <select id="status" class="form-control mb-2">
            <option value="1">Active</option>
            <option value="0">Inactive</option>
          </select>

          <textarea id="description" class="form-control" placeholder="Description"></textarea>

        </form>
      </div>

      <div class="modal-footer">
        <button class="btn btn-success w-100" id="saveBtn" onclick="save()">Add Subcategory</button>
      </div>

    </div>
  </div>
</div>

<style>
.main-content {
  margin-left: 250px;
  padding: 20px;
  background: #f8f9fa;
  min-height: 100vh;
}
</style>

<script>
function openModal(){
  document.getElementById('form').reset();
  document.getElementById('id').value = '';
  document.getElementById('modalTitle').innerText = "Add Subcategory";
  document.getElementById('saveBtn').innerText = "Add Subcategory";

  new bootstrap.Modal(document.getElementById('myModal')).show();
}

function editData(id,title,cat,status,desc){
  document.getElementById('id').value = id;
  document.getElementById('title').value = title;
  document.getElementById('category').value = cat;
  document.getElementById('status').value = status;
  document.getElementById('description').value = desc;

  document.getElementById('modalTitle').innerText = "Update Subcategory";
  document.getElementById('saveBtn').innerText = "Update Subcategory";

  new bootstrap.Modal(document.getElementById('myModal')).show();
}

function save(){
  const id = document.getElementById('id').value;

  const data = {
    id,
    title: document.getElementById('title').value,
    categorise_id: document.getElementById('category').value,
    status: document.getElementById('status').value,
    description: document.getElementById('description').value
  };

  const url = id ? '/subcategories_update' : '/subcategories_add';

  fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  }).then(() => location.reload());
}
</script>

<%- include('layout/footer') %>
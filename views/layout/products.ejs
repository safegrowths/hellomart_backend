<%- include('layout/header', { title: 'Product Attributes', showNavigation: true }) %>
<%- include('layout/sidebar', { currentPage: 'product-attributes' }) %>

<div class="main-content">
  <div class="page-header">
    <h1><i class="fas fa-tags"></i> Product Attribute Management</h1>
    <p>View dynamic attribute data from <code>productattribute</code> JSON column</p>
  </div>

  <% if (products && products.length) { %>
    <div class="attributes-container">
      <% products.forEach(product => { %>
        <div class="product-card">
          <div class="product-header">
            <h3><%= product.vendor_name || 'Unnamed Product' %> (ID: <%= product.id %>)</h3>
            <span class="badge">Category ID: <%= product.category_id || '—' %></span>
          </div>
          
          <% if (product.attributes && product.attributes.length) { %>
            <div class="table-responsive">
              <table class="attributes-table">
                <thead>
                  <tr>
                    <th>Attribute ID</th>
                    <th>Variant Name</th>
                    <th>Price (₹)</th>
                    <th>Weight</th>
                    <th>Discounted Price</th>
                    <th>Stock</th>
                    <th>Image</th>
                  </tr>
                </thead>
                <tbody>
                  <% product.attributes.forEach(attr => { %>
                    <tr>
                      <td><%= attr.id || '—' %></td>
                      <td><%= attr.name || 'Default' %></td>
                      <td><%= attr.price ? '₹' + parseFloat(attr.price).toLocaleString() : '—' %></td>
                      <td><%= attr.weight || '—' %> <%= attr.grocery_type || '' %></td>
                      <td><%= attr.discounted_price ? '₹' + parseFloat(attr.discounted_price).toLocaleString() : '—' %></td>
                      <td class="<%= attr.stock == 0 ? 'out-of-stock' : 'in-stock' %>">
                        <%= attr.stock || 0 %> left
                      </td>
                      <td>
                        <% if (attr.image) { %>
                          <a href="<%= attr.image %>" target="_blank" class="image-link">
                            <i class="fas fa-image"></i> View
                          </a>
                        <% } else { %>—<% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="no-attributes">⚠️ No valid attribute data found for this product.</div>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="alert alert-info">No products with attributes found in database.</div>
  <% } %>
</div>

<style>
  .main-content {
    padding: 24px 32px;
    background: #f8fafc;
    min-height: 100vh;
  }
  .page-header {
    margin-bottom: 28px;
  }
  .product-card {
    background: white;
    border-radius: 24px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    margin-bottom: 32px;
    padding: 20px;
    border: 1px solid #eef2ff;
  }
  .product-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #eef2ff;
    padding-bottom: 12px;
    margin-bottom: 20px;
  }
  .badge {
    background: #eef2ff;
    padding: 6px 14px;
    border-radius: 30px;
    font-size: 0.75rem;
    font-weight: 500;
  }
  .attributes-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }
  .attributes-table th {
    text-align: left;
    background: #f1f5f9;
    padding: 12px 10px;
  }
  .attributes-table td {
    padding: 10px;
    border-bottom: 1px solid #eef2ff;
  }
  .in-stock {
    color: #10b981;
    font-weight: 600;
  }
  .out-of-stock {
    color: #ef4444;
  }
  .image-link {
    color: #4f46e5;
    text-decoration: none;
  }
  .no-attributes {
    background: #fef9e3;
    padding: 12px;
    border-radius: 16px;
    color: #b45309;
  }
  .alert-info {
    background: #e0f2fe;
    padding: 20px;
    border-radius: 20px;
    text-align: center;
  }
  @media (max-width: 768px) {
    .attributes-table {
      font-size: 0.7rem;
    }
    .product-header {
      flex-direction: column;
      align-items: start;
      gap: 10px;
    }
  }
</style>

<%- include('layout/footer', { pageScript: 'product-attributes-init.js' }) %>
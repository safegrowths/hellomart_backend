<%- include('layout/header', { title: 'Subcategories List', showNavigation: true }) %>
<%- include('layout/sidebar', { currentPage: 'subcategories-list' }) %>

<!-- Main Content Area -->
<div class="main-content" style="margin-left: 250px; padding: 20px; background: #f8f9fa; min-height: 100vh;">
  <div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0 text-gray-800">Subcategories Management</h1>
      <button type="button" class="btn btn-primary" id="addSubcategoryBtn">
        <i class="fas fa-plus"></i> Add New Subcategory
      </button>
    </div>

    <!-- Subcategories Card -->
    <div class="card shadow">
      <div class="card-header bg-white py-3">
        <ul class="nav nav-tabs card-header-tabs" id="subcategoryTabs" role="tablist">
          <li class="nav-item">
            <button class="nav-link active" id="active-tab" data-bs-toggle="tab" 
                    data-bs-target="#active" type="button" role="tab">
              Active Subcategories
              <span class="badge bg-success ms-1" id="activeCount">0</span>
            </button>
          </li>
          <li class="nav-item">
            <button class="nav-link" id="inactive-tab" data-bs-toggle="tab" 
                    data-bs-target="#inactive" type="button" role="tab">
              Inactive Subcategories
              <span class="badge bg-secondary ms-1" id="inactiveCount">0</span>
            </button>
          </li>
        </ul>
      </div>
      <div class="card-body">
        <div class="tab-content" id="subcategoryTabsContent">
          <!-- Active Subcategories Tab -->
          <div class="tab-pane fade show active" id="active" role="tabpanel">
            <div class="table-responsive">
              <table class="table table-hover table-bordered">
                <thead class="table-light">
                  32<
                    <th width="5%">ID</th>
                    <th width="15%">Parent Category</th>
                    <th width="20%">Subcategory Name</th>
                    <th width="15%">Slug</th>
                    <th width="10%">Status</th>
                    <th width="15%">Created Date</th>
                    <th width="20%">Actions</th>
                  </tr>
                </thead>
                <tbody id="activeSubcategoriesList">
                  <tr>
                    <td colspan="7" class="text-center text-muted py-4">No active subcategories found</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Inactive Subcategories Tab -->
          <div class="tab-pane fade" id="inactive" role="tabpanel">
            <div class="table-responsive">
              <table class="table table-hover table-bordered">
                <thead class="table-light">
                  <tr>
                    <th width="5%">ID</th>
                    <th width="15%">Parent Category</th>
                    <th width="20%">Subcategory Name</th>
                    <th width="15%">Slug</th>
                    <th width="10%">Status</th>
                    <th width="15%">Created Date</th>
                    <th width="20%">Actions</th>
                  </tr>
                </thead>
                <tbody id="inactiveSubcategoriesList">
                  <tr>
                    <td colspan="7" class="text-center text-muted py-4">No inactive subcategories found</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal for Add/Edit Subcategory -->
<div class="modal fade" id="subcategoryModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="subcategoryModalLabel">Add New Subcategory</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="subcategoryForm">
          <div class="mb-3">
            <label for="parentCategory" class="form-label fw-bold">Parent Category <span class="text-danger">*</span></label>
            <select class="form-select" id="parentCategory" required>
              <option value="">Select Category</option>
            </select>
          </div>
          <div class="mb-3">
            <label for="subcategoryName" class="form-label fw-bold">Subcategory Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="subcategoryName" required 
                   placeholder="Enter subcategory name">
          </div>
          <div class="mb-3">
            <label for="subcategorySlug" class="form-label fw-bold">Slug</label>
            <input type="text" class="form-control" id="subcategorySlug" 
                   placeholder="auto-generated from name">
            <small class="text-muted">Leave empty to auto-generate</small>
          </div>
          <div class="mb-3">
            <label for="subcategoryStatus" class="form-label fw-bold">Status</label>
            <select class="form-select" id="subcategoryStatus">
              <option value="active">Active</option>
              <option value="inactive">Inactive</option>
            </select>
          </div>
          <div class="mb-3">
            <label for="subcategoryDescription" class="form-label fw-bold">Description</label>
            <textarea class="form-control" id="subcategoryDescription" rows="3" 
                      placeholder="Subcategory description (optional)"></textarea>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="saveSubcategoryBtn">Save Subcategory</button>
      </div>
    </div>
  </div>
</div>

<style>
.main-content {
  margin-left: 250px;
  padding: 20px;
  background: #f8f9fa;
  min-height: 100vh;
}

.card {
  border: none;
  border-radius: 10px;
}

.card-header {
  border-bottom: 1px solid #e3e6f0;
  background: white;
}

.table th {
  font-weight: 600;
  color: #4e73df;
  border-bottom-width: 1px;
}

.btn-sm {
  margin: 0 2px;
  padding: 5px 10px;
}

.badge {
  font-size: 12px;
  padding: 5px 8px;
}

@media (max-width: 768px) {
  .main-content {
    margin-left: 0;
    padding: 15px;
  }
}
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
$(document).ready(function() {
    // Categories data
    let categories = [
        { id: 1, name: "Electronics", slug: "electronics" },
        { id: 2, name: "Clothing", slug: "clothing" },
        { id: 3, name: "Books", slug: "books" },
        { id: 4, name: "Home & Garden", slug: "home-garden" },
        { id: 5, name: "Sports", slug: "sports" }
    ];
    
    // 10 DEMO SUBCATEGORIES DATA
    let subcategories = [
        {
            id: 1,
            parentId: 1,
            name: "Smartphones",
            slug: "smartphones",
            status: "active",
            description: "Latest smartphones and mobile devices",
            createdDate: new Date(2024, 0, 15)
        },
        {
            id: 2,
            parentId: 1,
            name: "Laptops",
            slug: "laptops",
            status: "active",
            description: "Notebooks and laptops for work and gaming",
            createdDate: new Date(2024, 0, 20)
        },
        {
            id: 3,
            parentId: 1,
            name: "Headphones",
            slug: "headphones",
            status: "inactive",
            description: "Wireless and wired headphones",
            createdDate: new Date(2024, 1, 5)
        },
        {
            id: 4,
            parentId: 2,
            name: "Men's Clothing",
            slug: "mens-clothing",
            status: "active",
            description: "Shirts, pants, jackets for men",
            createdDate: new Date(2024, 1, 10)
        },
        {
            id: 5,
            parentId: 2,
            name: "Women's Clothing",
            slug: "womens-clothing",
            status: "active",
            description: "Dresses, tops, bottoms for women",
            createdDate: new Date(2024, 1, 12)
        },
        {
            id: 6,
            parentId: 2,
            name: "Kids Wear",
            slug: "kids-wear",
            status: "inactive",
            description: "Clothing for children of all ages",
            createdDate: new Date(2024, 1, 15)
        },
        {
            id: 7,
            parentId: 3,
            name: "Fiction Books",
            slug: "fiction-books",
            status: "active",
            description: "Novels, stories, and fictional literature",
            createdDate: new Date(2024, 1, 18)
        },
        {
            id: 8,
            parentId: 3,
            name: "Educational Books",
            slug: "educational-books",
            status: "active",
            description: "Textbooks and learning materials",
            createdDate: new Date(2024, 1, 20)
        },
        {
            id: 9,
            parentId: 4,
            name: "Garden Tools",
            slug: "garden-tools",
            status: "inactive",
            description: "Tools for gardening and landscaping",
            createdDate: new Date(2024, 2, 1)
        },
        {
            id: 10,
            parentId: 5,
            name: "Football Equipment",
            slug: "football-equipment",
            status: "active",
            description: "Soccer balls, cleats, and gear",
            createdDate: new Date(2024, 2, 5)
        }
    ];
    
    let editingId = null;

    // Load categories into dropdown
    function loadCategories() {
        const select = $('#parentCategory');
        select.html('<option value="">Select Category</option>' + 
            categories.map(cat => `<option value="${cat.id}">${escapeHtml(cat.name)}</option>`).join(''));
    }

    // Generate slug
    function generateSlug(name) {
        return name.toLowerCase()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-+|-+$/g, '');
    }

    // Auto-generate slug from name
    $('#subcategoryName').on('input', function() {
        const slugInput = $('#subcategorySlug');
        if (!slugInput.val() || slugInput.val() === generateSlug(this.value)) {
            slugInput.val(generateSlug(this.value));
        }
    });

    // Render subcategories
    function renderSubcategories() {
        const activeSubs = subcategories.filter(sub => sub.status === 'active');
        const inactiveSubs = subcategories.filter(sub => sub.status === 'inactive');
        
        $('#activeCount').text(activeSubs.length);
        $('#inactiveCount').text(inactiveSubs.length);
        
        // Active subcategories
        const activeList = $('#activeSubcategoriesList');
        if (activeSubs.length === 0) {
            activeList.html('<tr><td colspan="7" class="text-center text-muted py-4">No active subcategories found</td></tr>');
        } else {
            activeList.html(activeSubs.map(sub => {
                const parentCat = categories.find(cat => cat.id === sub.parentId);
                return `
                    <tr>
                        <td>${sub.id}</td>
                        <td><span class="badge bg-info">${escapeHtml(parentCat?.name || 'N/A')}</span></td>
                        <td><strong>${escapeHtml(sub.name)}</strong></td>
                        <td><code>${escapeHtml(sub.slug)}</code></td>
                        <td><span class="badge bg-success">Active</span></td>
                        <td>${formatDate(sub.createdDate)}</td>
                        <td>
                            <button class="btn btn-sm btn-info" onclick="editSubcategory(${sub.id})">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                            <button class="btn btn-sm btn-warning" onclick="toggleStatus(${sub.id})">
                                <i class="fas fa-ban"></i> Deactivate
                            </button>
                            <button class="btn btn-sm btn-danger" onclick="deleteSubcategory(${sub.id})">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                `;
            }).join(''));
        }
        
        // Inactive subcategories
        const inactiveList = $('#inactiveSubcategoriesList');
        if (inactiveSubs.length === 0) {
            inactiveList.html('<tr><td colspan="7" class="text-center text-muted py-4">No inactive subcategories found</td></tr>');
        } else {
            inactiveList.html(inactiveSubs.map(sub => {
                const parentCat = categories.find(cat => cat.id === sub.parentId);
                return `
                    <tr>
                        <td>${sub.id}</td>
                        <td><span class="badge bg-info">${escapeHtml(parentCat?.name || 'N/A')}</span></td>
                        <td><strong>${escapeHtml(sub.name)}</strong></td>
                        <td><code>${escapeHtml(sub.slug)}</code></td>
                        <td><span class="badge bg-secondary">Inactive</span></td>
                        <td>${formatDate(sub.createdDate)}</td>
                        <td>
                            <button class="btn btn-sm btn-info" onclick="editSubcategory(${sub.id})">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                            <button class="btn btn-sm btn-success" onclick="toggleStatus(${sub.id})">
                                <i class="fas fa-check"></i> Activate
                            </button>
                            <button class="btn btn-sm btn-danger" onclick="deleteSubcategory(${sub.id})">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                `;
            }).join(''));
        }
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    function formatDate(date) {
        return new Date(date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric'
        });
    }

    // CRUD Operations
    window.addSubcategory = function(subcategoryData) {
        const newId = subcategories.length > 0 ? Math.max(...subcategories.map(s => s.id)) + 1 : 1;
        const newSubcategory = {
            id: newId,
            ...subcategoryData,
            createdDate: new Date()
        };
        subcategories.push(newSubcategory);
        renderSubcategories();
    }

    window.updateSubcategory = function(id, subcategoryData) {
        const index = subcategories.findIndex(sub => sub.id === id);
        if (index !== -1) {
            subcategories[index] = { ...subcategories[index], ...subcategoryData };
            renderSubcategories();
        }
    }

    window.deleteSubcategory = function(id) {
        if (confirm('Are you sure you want to delete this subcategory?')) {
            subcategories = subcategories.filter(sub => sub.id !== id);
            renderSubcategories();
            alert('Subcategory deleted successfully');
        }
    }

    window.toggleStatus = function(id) {
        const subcategory = subcategories.find(sub => sub.id === id);
        if (subcategory) {
            subcategory.status = subcategory.status === 'active' ? 'inactive' : 'active';
            renderSubcategories();
            alert(`Subcategory ${subcategory.status === 'active' ? 'activated' : 'deactivated'} successfully`);
        }
    }

    window.editSubcategory = function(id) {
        const subcategory = subcategories.find(sub => sub.id === id);
        if (subcategory) {
            editingId = id;
            $('#subcategoryModalLabel').text('Edit Subcategory');
            $('#parentCategory').val(subcategory.parentId);
            $('#subcategoryName').val(subcategory.name);
            $('#subcategorySlug').val(subcategory.slug);
            $('#subcategoryStatus').val(subcategory.status);
            $('#subcategoryDescription').val(subcategory.description || '');
            $('#subcategoryModal').modal('show');
        }
    }

    // Event Listeners
    $('#addSubcategoryBtn').click(function() {
        editingId = null;
        $('#subcategoryModalLabel').text('Add New Subcategory');
        $('#subcategoryForm')[0].reset();
        loadCategories();
        $('#subcategoryModal').modal('show');
    });

    $('#saveSubcategoryBtn').click(function() {
        const parentId = $('#parentCategory').val();
        const name = $('#subcategoryName').val().trim();
        
        if (!parentId) {
            alert('Please select a parent category');
            return;
        }
        
        if (!name) {
            alert('Please enter subcategory name');
            return;
        }
        
        let slug = $('#subcategorySlug').val().trim();
        if (!slug) {
            slug = generateSlug(name);
        }
        
        const subcategoryData = {
            parentId: parseInt(parentId),
            name: name,
            slug: slug,
            status: $('#subcategoryStatus').val(),
            description: $('#subcategoryDescription').val()
        };
        
        if (editingId) {
            updateSubcategory(editingId, subcategoryData);
        } else {
            addSubcategory(subcategoryData);
        }
        
        $('#subcategoryModal').modal('hide');
        $('#subcategoryForm')[0].reset();
        alert('Subcategory saved successfully');
    });

    // Initial render
    loadCategories();
    renderSubcategories();
});
</script>

<%- include('layout/footer', { pageScript: 'subcategories-init.min.js' }) %>
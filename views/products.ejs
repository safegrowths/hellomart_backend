<%- include('layout/header', { title: 'Product Attributes', showNavigation: true }) %>
<%- include('layout/sidebar', { currentPage: 'product-attributes' }) %>

<div class="main-content">
  <div class="page-header">
    <h1><i class="fas fa-table"></i> Product Attributes – Master Table View</h1>
    <p>All product attributes flattened into a single table</p>
  </div>

  <% 
    // Flatten all products and their attributes into one array
    let flatRows = [];
    if (products && products.length) {
      products.forEach(product => {
        let attributes = product.attributes;
        if (typeof attributes === 'string') {
          try { attributes = JSON.parse(attributes); } catch(e) { attributes = []; }
        }
        if (!Array.isArray(attributes)) attributes = [];
        
        // If no attributes, still show one row with empty attribute data
        if (attributes.length === 0) {
          flatRows.push({
            product_id: product.id,
            vendor_name: product.vendor_name || 'Unnamed Product',
            category_id: product.category_id || '—',
            attr_id: '—',
            attr_name: '—',
            price: null,
            weight: '—',
            grocery_type: '',
            discounted_price: null,
            stock: 0,
            image: ''
          });
        } else {
          attributes.forEach(attr => {
            flatRows.push({
              product_id: product.id,
              vendor_name: product.vendor_name || 'Unnamed Product',
              category_id: product.category_id || '—',
              attr_id: attr.id || '—',
              attr_name: attr.name || 'Default',
              price: attr.price && !isNaN(parseFloat(attr.price)) ? parseFloat(attr.price) : null,
              weight: attr.weight || '—',
              grocery_type: attr.grocery_type || '',
              discounted_price: attr.discounted_price && !isNaN(parseFloat(attr.discounted_price)) ? parseFloat(attr.discounted_price) : null,
              stock: (attr.stock !== undefined && attr.stock !== null) ? parseInt(attr.stock) : 0,
              image: attr.image && typeof attr.image === 'string' ? attr.image.trim() : ''
            });
          });
        }
      });
    }
  %>

  <% if (flatRows.length) { %>
    <div class="table-container">
      <div class="table-responsive">
        <table class="master-table">
          <thead>
            <tr>
              <th>Product Name</th>
              <th>Category ID</th>
              <th>Attr ID</th>
              <th>Variant Name</th>
              <th>Price (₹)</th>
              <th>Weight</th>
              <th>Disc. Price (₹)</th>
              <th>Stock</th>
              <th>Image</th>
            </tr>
          </thead>
          <tbody>
            <% flatRows.forEach(row => { %>
              <tr>
                <td data-label="Product Name">
                  <%= row.vendor_name %>
                  <small class="product-id">(ID: <%= row.product_id %>)</small>
                </td>
                <td data-label="Category ID"><%= row.category_id %></td>
                <td data-label="Attr ID"><%= row.attr_id %></td>
                <td data-label="Variant Name"><strong><%= row.attr_name %></strong></td>
                <td data-label="Price (₹)" class="price-cell">
                  <%= row.price ? '₹' + row.price.toLocaleString('en-IN') : '—' %>
                </td>
                <td data-label="Weight">
                  <%= row.weight %> <%= row.grocery_type %>
                </td>
                <td data-label="Disc. Price (₹)" class="price-cell">
                  <%= row.discounted_price ? '₹' + row.discounted_price.toLocaleString('en-IN') : '—' %>
                </td>
                <td data-label="Stock" class="<%= row.stock == 0 ? 'out-of-stock' : 'in-stock' %>">
                  <%= row.stock %> left
                </td>
                <td data-label="Image">
                  <% if (row.image) { %>
                    <a href="<%= row.image %>" target="_blank" rel="noopener noreferrer" class="image-link">
                      <i class="fas fa-external-link-alt"></i> View
                    </a>
                  <% } else { %>—<% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } else { %>
    <div class="alert alert-info">
      <i class="fas fa-info-circle"></i> No products with attributes found in database.
    </div>
  <% } %>
</div>

<style>
  * {
    box-sizing: border-box;
  }
  .main-content {
    padding: 28px 32px;
    background: #f1f5f9;
    min-height: 100vh;
  }
  .page-header {
    margin-bottom: 28px;
  }
  .page-header h1 {
    font-size: 1.8rem;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 6px;
  }
  .page-header p {
    color: #475569;
    font-size: 0.9rem;
  }
  .table-container {
    background: white;
    border-radius: 24px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.05);
    border: 1px solid #e2e8f0;
    overflow: hidden;
  }
  .table-responsive {
    overflow-x: auto;
  }
  .master-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    min-width: 900px;
  }
  .master-table th {
    text-align: left;
    background: #f8fafc;
    padding: 16px 14px;
    font-weight: 600;
    color: #1e293b;
    border-bottom: 2px solid #e2e8f0;
    font-size: 0.85rem;
  }
  .master-table td {
    padding: 14px;
    border-bottom: 1px solid #f0f2f5;
    vertical-align: middle;
    color: #1e293b;
  }
  .master-table tbody tr:hover {
    background-color: #fefce8;
  }
  .product-id {
    font-size: 0.7rem;
    color: #64748b;
    margin-left: 6px;
  }
  .price-cell {
    font-weight: 600;
    color: #0f3b2c;
  }
  .in-stock {
    color: #10b981;
    font-weight: 700;
    background: #e6f7ec;
    display: inline-block;
    padding: 4px 10px;
    border-radius: 30px;
    font-size: 0.75rem;
    white-space: nowrap;
  }
  .out-of-stock {
    color: #ef4444;
    font-weight: 700;
    background: #fee2e2;
    display: inline-block;
    padding: 4px 10px;
    border-radius: 30px;
    font-size: 0.75rem;
    white-space: nowrap;
  }
  .image-link {
    color: #4f46e5;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #f1f5f9;
    padding: 5px 12px;
    border-radius: 30px;
    font-size: 0.7rem;
    transition: all 0.2s;
    font-weight: 500;
    white-space: nowrap;
  }
  .image-link:hover {
    background: #e0e7ff;
    text-decoration: none;
    color: #3730a3;
  }
  .alert-info {
    background: #e0f2fe;
    padding: 24px;
    border-radius: 24px;
    text-align: center;
    color: #0369a1;
    font-weight: 500;
  }
  /* Mobile responsive: labels for each cell */
  @media (max-width: 768px) {
    .main-content {
      padding: 16px;
    }
    .master-table {
      min-width: 100%;
    }
    .master-table thead {
      display: none;
    }
    .master-table tbody tr {
      display: block;
      margin-bottom: 20px;
      border: 1px solid #e2e8f0;
      border-radius: 20px;
      padding: 12px;
      background: white;
    }
    .master-table td {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 10px 8px;
      border-bottom: 1px solid #eef2ff;
    }
    .master-table td:last-child {
      border-bottom: none;
    }
    .master-table td::before {
      content: attr(data-label);
      font-weight: 600;
      width: 40%;
      color: #334155;
      font-size: 0.75rem;
    }
    .in-stock, .out-of-stock {
      white-space: normal;
    }
  }
  @media (max-width: 480px) {
    .master-table td {
      flex-direction: column;
      align-items: flex-start;
    }
    .master-table td::before {
      width: 100%;
      margin-bottom: 4px;
    }
  }
</style>

<%- include('layout/footer', { pageScript: 'product-attributes-init.js' }) %>
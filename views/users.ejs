<%- include('../layout/header') %>
<%- include('../layout/sidebar') %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<!-- Chart.js for optional analytics -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<div class="content-body">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-sm-8">
                                <h4 class="card-title">Users List</h4>
                            </div>
                            <div class="col-sm-4">
                                <%- include('../utils/searchbox') %>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>Sr. No</th>
                                        <th>Name</th>
                                        <th>Username</th>
                                        <th>Mobile</th>
                                        <th>DOB</th>
                                        <th>Email</th>
                                        <th>Image</th>
                                        <th>Status</th>
                                        <th>Total Orders</th>
                                        <th>Total Spent (₹)</th>
                                        <th>Created At</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (data && data.length > 0) { %>
                                        <% data.forEach(function(user, index) { %>
                                            <tr>
                                                <td><%= ((currentPage - 1) * limit) + index + 1 %></td>
                                                <td><%= user.name %></td>
                                                <td><%= user.username || user.name %></td>
                                                <td><%= user.mobile || '-' %></td>
                                                <td><%= user.dob || '-' %></td>
                                                <td><%= user.email %></td>
                                                <td>
                                                    <img src="<%= user.profile_pic || user.image %>" height="50" width="50"
                                                         onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/a/a3/Image-not-found.png';"
                                                         style="border-radius:50px;border:2px solid black">
                                                </td>
                                                <td>
                                                    <% if (user.status == 1) { %>
                                                        <span class="badge bg-success">Active</span>
                                                        <button class="btn btn-sm btn-warning toggle-status ms-1" data-id="<%= user.id %>" data-status="0">Block</button>
                                                    <% } else if (user.status == 2) { %>
                                                        <span class="badge bg-danger">Reject</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary">Inactive</span>
                                                        <button class="btn btn-sm btn-success toggle-status ms-1" data-id="<%= user.id %>" data-status="1">Unblock</button>
                                                    <% } %>
                                                </td>
                                                <td><%= user.totalOrders %></td>
                                                <td>₹<%= user.totalSpent.toLocaleString() %></td>
                                                <td><%= new Date(user.created_at).toLocaleDateString() %></td>
                                                <td>
                                                    <button class="btn btn-sm btn-info order-history-btn" data-id="<%= user.id %>" data-name="<%= user.name %>">
                                                        <i class="fa-solid fa-receipt"></i> History
                                                    </button>
                                                    <i class="fa-solid fa-pen text-primary ms-2"></i>
                                                    <i class="fa-solid fa-trash text-danger ms-1"></i>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="12" class="text-center">No Data Found</td></tr>
                                    <% } %>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <th>Sr. No</th>
                                        <th>Name</th>
                                        <th>Username</th>
                                        <th>Mobile</th>
                                        <th>DOB</th>
                                        <th>Email</th>
                                        <th>Image</th>
                                        <th>Status</th>
                                        <th>Total Orders</th>
                                        <th>Total Spent (₹)</th>
                                        <th>Created At</th>
                                        <th>Action</th>
                                    </tr>
                                </tfoot>
                            </table>
                            <%- include('../utils/pagination') %>
                        </div>
                    </div>
                </div>

                <!-- Optional: Order Analytics Chart -->
                <div class="card mt-3">
                    <div class="card-body">
                        <h5>Recent Order Trends (Last 7 orders)</h5>
                        <canvas id="orderChart" height="100"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Order History Modal -->
<div class="modal fade" id="orderHistoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Order History</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="orderHistoryBody">
                Loading...
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Chart rendering (using chartOrders passed from controller)
    const chartOrders = <%- JSON.stringify(chartOrders || []) %>;
    if (chartOrders.length) {
        const ctx = document.getElementById('orderChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: chartOrders.map((_, i) => `Order ${i+1}`),
                datasets: [{
                    label: 'Order Amount (₹)',
                    data: chartOrders,
                    borderColor: '#4f46e5',
                    backgroundColor: 'rgba(79,70,229,0.1)',
                    tension: 0.3,
                    fill: true
                }]
            }
        });
    }

    // Order History Modal
    document.querySelectorAll('.order-history-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const userId = btn.dataset.id;
            const userName = btn.dataset.name;
            const modalBody = document.getElementById('orderHistoryBody');
            modalBody.innerHTML = 'Loading orders...';
            try {
                const response = await fetch(`/api/users/${userId}/orders`);
                const orders = await response.json();
                if (orders.length === 0) {
                    modalBody.innerHTML = '<p>No orders found for this user.</p>';
                } else {
                    let total = 0;
                    let html = `<p><strong>${userName}</strong> - ${orders.length} order(s)</p><ul class="list-group">`;
                    orders.forEach(order => {
                        total += order.amount;
                        html += `<li class="list-group-item">₹${order.amount.toLocaleString()} - ${new Date(order.date).toLocaleString()}</li>`;
                    });
                    html += `<li class="list-group-item active">Total: ₹${total.toLocaleString()}</li></ul>`;
                    modalBody.innerHTML = html;
                }
                new bootstrap.Modal(document.getElementById('orderHistoryModal')).show();
            } catch (err) {
                modalBody.innerHTML = '<p class="text-danger">Failed to load orders.</p>';
            }
        });
    });

    // Block / Unblock toggle
    document.querySelectorAll('.toggle-status').forEach(btn => {
        btn.addEventListener('click', async () => {
            const userId = btn.dataset.id;
            const newStatus = btn.dataset.status; // 1 or 0
            if (confirm(`Change user status to ${newStatus == 1 ? 'Active' : 'Inactive'}?`)) {
                const res = await fetch(`/api/users/${userId}/status`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: parseInt(newStatus) })
                });
                if (res.ok) {
                    location.reload();
                } else {
                    alert('Failed to update status');
                }
            }
        });
    });
</script>

<%- include('../layout/footer') %>
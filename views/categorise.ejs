<%- include('layout/header', { title: 'Categories List', showNavigation: true }) %>
<%- include('layout/sidebar', { currentPage: 'categories-list' }) %>

<div class="container mt-4">
  <!-- Header -->
  <div class="d-flex justify-content-between mb-3">
    <h3>Category Management</h3>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#categoryModal">
      + Add Category
    </button>
  </div>

  <!-- Tabs -->
  <ul class="nav nav-tabs" id="categoryTabs" role="tablist">
    <li class="nav-item">
      <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#active" type="button" role="tab">
        Active (<span id="activeCount">0</span>)
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#inactive" type="button" role="tab">
        Inactive (<span id="inactiveCount">0</span>)
      </button>
    </li>
  </ul>

  <div class="tab-content mt-3">
    <!-- Active Tab -->
    <div class="tab-pane fade show active" id="active" role="tabpanel">
      <table class="table table-bordered">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Type</th>
            <th>Date</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="activeList">
          <tr><td colspan="5" class="text-center">Loading...</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Inactive Tab -->
    <div class="tab-pane fade" id="inactive" role="tabpanel">
      <table class="table table-bordered">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Type</th>
            <th>Date</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="inactiveList">
          <tr><td colspan="5" class="text-center">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal -->
<div class="modal fade" id="categoryModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title">Add Category</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="text" id="catName" class="form-control mb-2" placeholder="Category Name">
        <select id="catType" class="form-control mb-2">
          <option value="1">Normal</option>
          <option value="2">50% OFF</option>
          <option value="3">100% Cashback</option>
        </select>
        <select id="catStatus" class="form-control">
          <option value="1">Active</option>
          <option value="0">Inactive</option>
        </select>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="saveCategoryBtn">Save Category</button>
      </div>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
  // Helper: format date
  function formatDate(dateStr) {
    if (!dateStr) return 'N/A';
    return new Date(dateStr).toLocaleDateString();
  }

  // Load categories from API
  function loadCategories() {
    $.get('/api/categories', function(res) {
      if (!res.status) {
        alert('Failed to load categories');
        return;
      }
      const categories = res.data;
      const active = categories.filter(c => c.status == 1);
      const inactive = categories.filter(c => c.status == 0);

      $('#activeCount').text(active.length);
      $('#inactiveCount').text(inactive.length);

      renderTable(active, '#activeList');
      renderTable(inactive, '#inactiveList');
    }).fail(() => alert('Error loading categories'));
  }

  function renderTable(data, selector) {
    if (!data.length) {
      $(selector).html('<tr><td colspan="5" class="text-center text-muted">No data</td></tr>');
      return;
    }

    let html = '';
    data.forEach(c => {
      let typeText = '';
      if (c.type == 1) typeText = 'Normal';
      else if (c.type == 2) typeText = '50% OFF';
      else typeText = '100% Cashback';

      html += `
        <tr>
          <td>${c.id}</td>
          <td><strong>${escapeHtml(c.title)}</strong></td>
          <td>${typeText}</td>
          <td>${formatDate(c.created_at)}</td>
          <td>
            <button class="btn btn-warning btn-sm" onclick="toggleStatus(${c.id})">
              Toggle
            </button>
            <button class="btn btn-danger btn-sm" onclick="deleteCategory(${c.id})">
              Delete
            </button>
          </td>
        </tr>
      `;
    });
    $(selector).html(html);
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  // Add new category
  $('#saveCategoryBtn').click(function() {
    const title = $('#catName').val().trim();
    if (!title) {
      alert('Category name is required');
      return;
    }

    const data = {
      title: title,
      type: $('#catType').val(),
      status: $('#catStatus').val()
    };

    $.post('/api/add-category', data, function(res) {
      if (res.status) {
        $('#categoryModal').modal('hide');
        // Clear form
        $('#catName').val('');
        $('#catType').val('1');
        $('#catStatus').val('1');
        loadCategories();  // refresh table
      } else {
        alert(res.msg || 'Error adding category');
      }
    }).fail(() => alert('Server error'));
  });

  // Toggle active/inactive
  window.toggleStatus = function(id) {
    $.post('/api/toggle-category', { id }, function(res) {
      if (res.status) loadCategories();
      else alert(res.msg || 'Toggle failed');
    }).fail(() => alert('Error'));
  };

  // Delete category
  window.deleteCategory = function(id) {
    if (confirm('Are you sure you want to delete this category?')) {
      $.post('/api/delete-category', { id }, function(res) {
        if (res.status) loadCategories();
        else alert(res.msg || 'Delete failed');
      }).fail(() => alert('Error'));
    }
  };

  // Initial load
  loadCategories();
</script>

<%- include('layout/footer') %>
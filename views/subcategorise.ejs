<%- include('layout/header', { title: 'Subcategories List', showNavigation: true }) %>
<%- include('layout/sidebar', { currentPage: 'subcategories-list' }) %>

<div class="main-content">
  <div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3>Subcategories Management</h3>

      <form method="GET" action="/subcategories" class="d-flex">
        <input type="text" name="search" value="<%= search %>" 
          class="form-control me-2" placeholder="Search...">
        <button class="btn btn-primary">Search</button>
      </form>
    </div>

    <!-- TABS -->
    <div class="mb-3">
      <a href="/subcategories?status=all" 
        class="btn <%= status=='all'?'btn-primary':'btn-outline-primary' %>">All</a>

      <a href="/subcategories?status=1" 
        class="btn <%= status=='1'?'btn-success':'btn-outline-success' %>">Active</a>

      <a href="/subcategories?status=0" 
        class="btn <%= status=='0'?'btn-secondary':'btn-outline-secondary' %>">Inactive</a>
    </div>

    <!-- TABLE -->
    <div class="card shadow">
      <div class="card-body">
        <div class="table-responsive">

          <table class="table table-bordered table-hover">
            <thead class="table-light">
              <tr>
                <th>ID</th>
                <th>Category</th>
                <th>Name</th>
                <th>Status</th>
                <th>Date</th>
                <th width="200">Actions</th>
              </tr>
            </thead>

            <tbody>
              <% if (subcategories.length === 0) { %>
                <tr>
                  <td colspan="6" class="text-center">No Data Found</td>
                </tr>
              <% } %>

              <% subcategories.forEach(sub => { %>
                <tr>
                  <td><%= sub.id %></td>

                  <td>
                    <span class="badge bg-info">
                      <%= sub.category_name || 'N/A' %>
                    </span>
                  </td>

                  <td><strong><%= sub.title %></strong></td>

                  <td>
                    <% if (sub.status == 1) { %>
                      <span class="badge bg-success">Active</span>
                    <% } else { %>
                      <span class="badge bg-secondary">Inactive</span>
                    <% } %>
                  </td>

                  <td>
                    <%= new Date(sub.created_at).toLocaleDateString() %>
                  </td>

                  <td>
                    <button class="btn btn-sm btn-info"
                      onclick="editData(
                        <%= sub.id %>,
                        '<%= sub.title %>',
                        <%= sub.categorise_id %>,
                        <%= sub.status %>,
                        `<%= sub.description || '' %>`
                      )">
                      Edit
                    </button>

                    <a href="/subcategories_status/<%= sub.id %>" 
                       class="btn btn-sm btn-warning">
                       Toggle
                    </a>

                    <a href="/subcategories_delete/<%= sub.id %>" 
                       onclick="return confirm('Delete?')" 
                       class="btn btn-sm btn-danger">
                       Delete
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>

        </div>

        <!-- PAGINATION -->
        <div class="d-flex justify-content-center mt-3">
          <% for(let i = 1; i <= totalPages; i++) { %>
            <a href="/subcategories?page=<%= i %>&search=<%= search %>&status=<%= status %>"
              class="btn <%= i==currentPage ? 'btn-primary':'btn-outline-primary' %> mx-1">
              <%= i %>
            </a>
          <% } %>
        </div>

      </div>
    </div>

  </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="myModal">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5>Add / Edit Subcategory</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <form id="form">

          <input type="hidden" id="id">

          <select id="category" class="form-control mb-2">
            <option value="">Select Category</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>"><%= cat.title %></option>
            <% }) %>
          </select>

          <input type="text" id="title" class="form-control mb-2" placeholder="Name">

          <select id="status" class="form-control mb-2">
            <option value="1">Active</option>
            <option value="0">Inactive</option>
          </select>

          <textarea id="description" class="form-control" placeholder="Description"></textarea>

        </form>
      </div>

      <div class="modal-footer">
        <button class="btn btn-primary" onclick="save()">Save</button>
      </div>

    </div>
  </div>
</div>

<button class="btn btn-primary"
  style="position:fixed;bottom:20px;right:20px"
  onclick="openModal()">
  + Add
</button>

<style>
.main-content {
  margin-left: 250px;
  padding: 20px;
  background: #f8f9fa;
  min-height: 100vh;
}
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
function openModal(){
  $('#form')[0].reset();
  $('#id').val('');
  $('#myModal').modal('show');
}

function editData(id,title,cat,status,desc){
  $('#id').val(id);
  $('#title').val(title);
  $('#category').val(cat);
  $('#status').val(status);
  $('#description').val(desc);
  $('#myModal').modal('show');
}

function save(){
  const id = $('#id').val();

  const data = {
    id: id,
    title: $('#title').val(),
    categorise_id: $('#category').val(),
    status: $('#status').val(),
    description: $('#description').val()
  };

  const url = id ? '/subcategories_update' : '/subcategories_add';

  $.post(url, data, function(){
    location.reload();
  });
}
</script>

<%- include('layout/footer') %>
<%- include('../layout/header') %>
<%- include('../layout/sidebar') %>


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<i class="fa-solid fa-pen"></i>
<!--**********************************
            Content body start
        ***********************************-->
        <div class="content-body">
            <!-- row -->

            <div class="container-fluid">
                
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-sm-8">
                                        <h4 class="card-title">Category List</h4>
                                    </div>
                                    <div class="col-sm-4">
                                        <%- include('../utils/searchbox') %>
                                    </div>
                                </div>
                                
                                <div class="table-responsive">
                                    <table id="myTable" class="table table-striped table-bordered zero-configuration">
                                        <thead>
                                            <tr>
                                                <th>Sr. No</th>
                                                <th>Name</th>
                                                <th>Image</th>
                                                <th>Status</th>
                                                <th>Created At</th>
                                                <th>Updated At</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (data && data.length > 0) { %>
                                                <% data.forEach(function(n, index) { %>
                                                    <tr>
                                                        <td><%= ((currentPage - 1) * 10) + index + 1 %></td>
                                                        <td><%= n.name %></td>
                                                        <td>
                                                            <img src="<%= n.image %>" height="50" width="50"
                                                                 onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/a/a3/Image-not-found.png';"
                                                                 style="border-radius:50px;border:2px solid black">
                                                        </td>
                                                        <td>
                                                            <% if (n.status == 1) { %>
                                                                <span class="text-success">Active</span>
                                                            <% } else if (n.status == 2) { %>
                                                                <span class="text-danger">Reject</span>
                                                            <% } else { %>
                                                                <span class="text-primary">Inactive</span>
                                                            <% } %>
                                                        </td>
                                                        <td><%= n.created_at %></td>
                                                        <td><%= n.updated_at %></td>
                                                        <td>
                                                            <i class="fa-solid fa-pen text-primary"></i>
                                                            <i class="fa-solid fa-trash text-danger"></i>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="7" class="text-center">No Data Found</td>
                                                </tr>
                                            <% } %>
                                            </tbody>

                                        <tfoot>
                                            <tr>
                                                <th>Sr. No</th>
                                                <th>Name</th>
                                                <th>Image</th>
                                                <th>Status</th>
                                                <th>Created At</th>
                                                <th>Updated At</th>
                                                <th>Action</th>
                                            </tr>
                                        </tfoot>
                                    </table>
                                    <%- include('../utils/pagination') %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- #/ container -->
        </div>
        <!--**********************************
            Content body end
        ***********************************-->

<%- include('../layout/footer') %>

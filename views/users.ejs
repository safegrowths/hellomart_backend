<%- include('layout/header', { title: 'Users', showNavigation: true }) %>
<%- include('layout/sidebar', { currentPage: 'users' }) %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Users | Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

    :root {
      --bg:        #f0f2f9;
      --surface:   #ffffff;
      --sidebar:   #0d1117;
      --primary:   #4f46e5;
      --primary-l: #818cf8;
      --success:   #10b981;
      --danger:    #ef4444;
      --warning:   #f59e0b;
      --text:      #0f172a;
      --muted:     #64748b;
      --border:    #e8edf5;
      --radius:    20px;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      display: flex;
      min-height: 100vh;
    }

    /* ═══ SIDEBAR ═══════════════════════════════════════════════════════════ */
    .sidebar {
      width: 260px;
      background: var(--sidebar);
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }
    .sidebar-logo {
      padding: 28px 24px 20px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .sidebar-logo h2 {
      font-size: 1.4rem;
      font-weight: 800;
      background: linear-gradient(135deg, #a78bfa, #60a5fa);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .sidebar-logo p { font-size:0.72rem; color:#475569; margin-top:4px; }
    .nav-menu { padding: 20px 16px; display:flex; flex-direction:column; gap:4px; }
    .nav-item {
      display: flex; align-items: center; gap: 12px;
      padding: 11px 16px; border-radius: 12px;
      font-size: 0.875rem; font-weight: 500;
      color: #64748b; cursor: pointer; transition: all 0.15s;
      text-decoration: none;
    }
    .nav-item i { width:18px; text-align:center; }
    .nav-item.active { background: rgba(99,102,241,0.15); color: #a5b4fc; }
    .nav-item:hover:not(.active) { background: rgba(255,255,255,0.04); color: #cbd5e1; }

    /* ═══ MAIN ═══════════════════════════════════════════════════════════════ */
    .main { flex:1; display:flex; flex-direction:column; min-width:0; }

    .topbar {
      background: var(--surface);
      padding: 16px 28px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }
    .topbar h1 { font-size:1.45rem; font-weight:700; }
    .topbar h1 span { color: var(--muted); font-weight:400; font-size:1rem; }
    .topbar-sub { font-size:0.8rem; color:var(--muted); margin-top:2px; }

    .content { padding: 24px 28px; }

    /* ═══ STAT CARDS ══════════════════════════════════════════════════════════ */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }
    .stat-card {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 20px;
      border: 1px solid var(--border);
      display: flex; align-items: center; gap: 16px;
    }
    .stat-icon {
      width: 48px; height: 48px;
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem; flex-shrink: 0;
    }
    .icon-blue   { background:#eff6ff; color:#3b82f6; }
    .icon-green  { background:#f0fdf4; color:#10b981; }
    .icon-red    { background:#fef2f2; color:#ef4444; }
    .icon-purple { background:#f5f3ff; color:#7c3aed; }
    .icon-amber  { background:#fffbeb; color:#f59e0b; }
    .stat-val { font-size:1.7rem; font-weight:800; line-height:1; }
    .stat-label { font-size:0.78rem; color:var(--muted); margin-top:4px; }

    /* ═══ SEARCH / FILTER BAR ════════════════════════════════════════════════ */
    .toolbar {
      background: var(--surface);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 14px 20px;
      margin-bottom: 18px;
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
    }
    .search-wrap {
      flex: 1; min-width: 220px;
      position: relative;
    }
    .search-wrap i {
      position: absolute; left: 14px; top: 50%;
      transform: translateY(-50%); color: var(--muted);
    }
    .search-wrap input {
      width: 100%;
      padding: 10px 14px 10px 38px;
      border: 1.5px solid var(--border);
      border-radius: 40px;
      font-family: inherit;
      font-size: 0.875rem;
      background: var(--bg);
      transition: border 0.2s;
    }
    .search-wrap input:focus {
      outline: none;
      border-color: var(--primary-l);
      box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
    }
    .filter-select {
      padding: 10px 14px;
      border: 1.5px solid var(--border);
      border-radius: 40px;
      font-family: inherit;
      font-size: 0.875rem;
      background: var(--bg);
      cursor: pointer;
    }
    .filter-select:focus { outline:none; border-color:var(--primary-l); }

    /* ═══ TABLE ══════════════════════════════════════════════════════════════ */
    .table-card {
      background: var(--surface);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      overflow: hidden;
      margin-bottom: 24px;
    }
    .table-card table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
    }
    .table-card thead th {
      padding: 14px 18px;
      text-align: left;
      font-weight: 600;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--muted);
      background: #f8faff;
      border-bottom: 1px solid var(--border);
    }
    .table-card tbody tr {
      border-bottom: 1px solid var(--border);
      transition: background 0.1s;
    }
    .table-card tbody tr:last-child { border-bottom: none; }
    .table-card tbody tr:hover { background: #f8faff; }
    .table-card td { padding: 14px 18px; vertical-align: middle; }

    .user-cell { display:flex; align-items:center; gap:12px; }
    .user-avatar {
      width: 38px; height: 38px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary), var(--primary-l));
      display: flex; align-items: center; justify-content: center;
      color: white; font-weight: 700; font-size: 0.9rem;
      flex-shrink: 0; overflow: hidden;
    }
    .user-avatar img { width:100%; height:100%; object-fit:cover; }
    .user-name { font-weight: 600; }
    .user-biz  { font-size: 0.75rem; color: var(--muted); }

    .badge {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 10px; border-radius: 40px;
      font-size: 0.72rem; font-weight: 600;
    }
    .badge-active   { background:#dcfce7; color:#15803d; }
    .badge-blocked  { background:#fee2e2; color:#b91c1c; }
    .badge-pending  { background:#fef9c3; color:#92400e; }

    .order-count {
      display: inline-flex; align-items: center; gap: 6px;
      font-weight: 700;
    }
    .order-count small { font-weight:400; color:var(--muted); font-size:0.75rem; }

    .action-group { display:flex; gap:8px; }
    .btn-icon {
      width: 32px; height: 32px;
      border-radius: 8px; border: none;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; font-size: 0.85rem; transition: all 0.15s;
    }
    .btn-icon.view    { background:#eff6ff; color:#3b82f6; }
    .btn-icon.view:hover   { background:#3b82f6; color:white; }
    .btn-icon.block   { background:#fef2f2; color:#ef4444; }
    .btn-icon.block:hover  { background:#ef4444; color:white; }
    .btn-icon.unblock { background:#f0fdf4; color:#10b981; }
    .btn-icon.unblock:hover{ background:#10b981; color:white; }

    .empty-row td {
      text-align: center; padding: 48px;
      color: var(--muted); font-size: 0.9rem;
    }

    /* ═══ CHART ═════════════════════════════════════════════════════════════ */
    .chart-card {
      background: var(--surface);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 20px 24px;
    }
    .chart-card h4 {
      font-size: 1rem; font-weight: 700; margin-bottom: 16px;
    }
    canvas { max-height: 240px; }

    /* ═══ MODAL ══════════════════════════════════════════════════════════════ */
    .modal-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.45);
      backdrop-filter: blur(4px);
      display: flex; align-items: center; justify-content: center;
      z-index: 9999;
      opacity: 0; visibility: hidden; transition: all 0.2s;
    }
    .modal-overlay.open { opacity: 1; visibility: visible; }
    .modal-box {
      background: white;
      border-radius: 24px;
      width: 90%; max-width: 560px;
      padding: 24px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.2);
      transform: translateY(20px); transition: transform 0.2s;
    }
    .modal-overlay.open .modal-box { transform: translateY(0); }
    .modal-title {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 18px;
    }
    .modal-title h3 { font-size: 1.1rem; font-weight: 700; }
    .close-btn {
      background: #f1f5f9; border: none; width: 30px; height: 30px;
      border-radius: 8px; cursor: pointer; font-size: 1rem;
      display:flex; align-items:center; justify-content:center;
    }
    .order-scroll { max-height: 380px; overflow-y: auto; display:flex; flex-direction:column; gap:10px; }
    .order-card {
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 14px 16px;
      border-left: 4px solid var(--primary);
    }
    .order-card .oid  { font-weight:700; font-size:0.85rem; }
    .order-card .ometa { font-size:0.75rem; color:var(--muted); margin-top:4px; }
    .order-card .oamt  { font-size:1.1rem; font-weight:800; color:var(--primary); margin-top:6px; }
    .items-list { margin-top:8px; display:flex; flex-direction:column; gap:4px; }
    .items-list span {
      font-size:0.75rem; color:var(--muted);
      background:#f8faff; border-radius:6px; padding:3px 8px;
    }

    /* Pagination */
    .pagination {
      display: flex; gap: 8px; align-items: center;
      justify-content: center; padding: 16px;
      border-top: 1px solid var(--border);
    }
    .pg-btn {
      padding: 6px 14px; border-radius: 8px;
      border: 1px solid var(--border);
      background: white; cursor: pointer; font-size: 0.8rem;
      font-family: inherit; transition: all 0.15s;
    }
    .pg-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
    .pg-btn:hover:not(.active) { background: var(--bg); }

    @media (max-width: 768px) {
      .sidebar { width: 64px; }
      .sidebar-logo p, .sidebar-logo h2 span, .nav-item span { display:none; }
      .nav-item { justify-content: center; padding: 12px; }
      .content { padding: 16px; }
    }
  </style>
</head>
<body>

<!-- ═══ SIDEBAR ══════════════════════════════════════════════════════════════ -->
<nav class="sidebar">
  <div class="sidebar-logo">
    <h2><i class="fas fa-crown"></i> AdminKit</h2>
    <p>control panel</p>
  </div>
  <div class="nav-menu">
    <a href="/admin/dashboard" class="nav-item"><i class="fas fa-tachometer-alt"></i><span>Dashboard</span></a>
    <a href="/admin/users"     class="nav-item active"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="/admin/orders"    class="nav-item"><i class="fas fa-shopping-cart"></i><span>Orders</span></a>
    <a href="/admin/analytics" class="nav-item"><i class="fas fa-chart-line"></i><span>Analytics</span></a>
    <a href="/admin/settings"  class="nav-item"><i class="fas fa-cog"></i><span>Settings</span></a>
  </div>
</nav>

<!-- ═══ MAIN ══════════════════════════════════════════════════════════════════ -->
<div class="main">

  <!-- Topbar -->
  <div class="topbar">
    <div>
      <h1>Users <span>/ Management</span></h1>
      <div class="topbar-sub">Real-time data from Railway database</div>
    </div>
    <div style="font-size:0.82rem; color:var(--muted);">
      <i class="fas fa-database"></i> <%= stats.totalUsers %> users loaded
    </div>
  </div>

  <div class="content">

    <!-- ── Stat Cards ──────────────────────────────────────────────────────── -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon icon-blue"><i class="fas fa-users"></i></div>
        <div>
          <div class="stat-val"><%= stats.totalUsers %></div>
          <div class="stat-label">Total Users</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon icon-green"><i class="fas fa-user-check"></i></div>
        <div>
          <div class="stat-val"><%= stats.activeUsers %></div>
          <div class="stat-label">Active</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon icon-red"><i class="fas fa-user-slash"></i></div>
        <div>
          <div class="stat-val"><%= stats.blockedUsers %></div>
          <div class="stat-label">Blocked</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon icon-amber"><i class="fas fa-shopping-bag"></i></div>
        <div>
          <div class="stat-val"><%= stats.totalOrders %></div>
          <div class="stat-label">Total Orders</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon icon-purple"><i class="fas fa-indian-rupee-sign"></i></div>
        <div>
          <div class="stat-val">₹<%= Number(stats.totalRevenue).toLocaleString('en-IN') %></div>
          <div class="stat-label">Revenue</div>
        </div>
      </div>
    </div>

    <!-- ── Toolbar ─────────────────────────────────────────────────────────── -->
    <div class="toolbar">
      <div class="search-wrap">
        <i class="fas fa-search"></i>
        <input type="text" id="searchInput" placeholder="Search users by name, email, mobile…">
      </div>
      <select class="filter-select" id="statusFilter">
        <option value="">All Status</option>
        <option value="active">Active</option>
        <option value="blocked">Blocked</option>
      </select>
      <select class="filter-select" id="orderFilter">
        <option value="">All Order Counts</option>
        <option value="0">No Orders</option>
        <option value="1">1+ Orders</option>
        <option value="5">5+ Orders</option>
      </select>
    </div>

    <!-- ── Users Table ─────────────────────────────────────────────────────── -->
    <div class="table-card">
      <table id="usersTable">
        <thead>
          <tr>
            <th>#</th>
            <th>User</th>
            <th>Mobile</th>
            <th>Status</th>
            <th>Orders</th>
            <th>Total Spent</th>
            <th>Joined</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="tableBody">
          <% if (users.length === 0) { %>
            <tr class="empty-row"><td colspan="8"><i class="fas fa-users-slash"></i> No users found</td></tr>
          <% } else { %>
            <% users.forEach((user, idx) => { %>
              <tr
                data-name="<%= user.name ? user.name.toLowerCase() : '' %>"
                data-email="<%= user.email ? user.email.toLowerCase() : '' %>"
                data-mobile="<%= user.mobile || '' %>"
                data-status="<%= user.isActive ? 'active' : 'blocked' %>"
                data-orders="<%= user.totalOrdersCount %>"
                data-id="<%= user.id %>"
              >
                <!-- # -->
                <td style="color:var(--muted); font-size:0.8rem;"><%= idx + 1 %></td>

                <!-- User -->
                <td>
                  <div class="user-cell">
                    <div class="user-avatar">
                      <% if (user.image) { %>
                        <img src="<%= user.image %>" alt="<%= user.name %>" onerror="this.style.display='none';this.parentNode.innerText='<%= (user.name || 'U').charAt(0).toUpperCase() %>'">
                      <% } else { %>
                        <%= (user.name || 'U').charAt(0).toUpperCase() %>
                      <% } %>
                    </div>
                    <div>
                      <div class="user-name"><%= user.name || '—' %></div>
                      <div class="user-biz"><%= user.email || '—' %></div>
                      <% if (user.business_name) { %>
                        <div class="user-biz" style="color:var(--primary-l);"><i class="fas fa-store fa-xs"></i> <%= user.business_name %></div>
                      <% } %>
                    </div>
                  </div>
                </td>

                <!-- Mobile -->
                <td><%= user.mobile || '—' %></td>

                <!-- Status -->
                <td>
                  <span class="badge <%= user.isActive ? 'badge-active' : 'badge-blocked' %>">
                    <i class="fas fa-circle" style="font-size:6px;"></i>
                    <%= user.isActive ? 'Active' : 'Blocked' %>
                  </span>
                </td>

                <!-- Order Count -->
                <td>
                  <div class="order-count">
                    <%= user.totalOrdersCount %>
                    <small>orders</small>
                  </div>
                </td>

                <!-- Total Spent -->
                <td>
                  <strong>₹<%= Number(user.totalSpent).toLocaleString('en-IN') %></strong>
                </td>

                <!-- Joined Date -->
                <td style="font-size:0.8rem; color:var(--muted);">
                  <%= user.created_at ? new Date(user.created_at).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) : '—' %>
                </td>

                <!-- Actions -->
                <td>
                  <div class="action-group">
                    <!-- View Orders -->
                    <button
                      class="btn-icon view"
                      title="View Order History"
                      onclick="showOrders(<%= user.id %>)"
                    ><i class="fas fa-receipt"></i></button>

                    <!-- Block / Unblock -->
                    <% if (user.isActive) { %>
                      <button class="btn-icon block" title="Block User" onclick="toggleStatus(<%= user.id %>, 'blocked')">
                        <i class="fas fa-ban"></i>
                      </button>
                    <% } else { %>
                      <button class="btn-icon unblock" title="Unblock User" onclick="toggleStatus(<%= user.id %>, 'active')">
                        <i class="fas fa-check-circle"></i>
                      </button>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>

      <div class="pagination" id="paginationWrapper"></div>
    </div>

    <!-- ── Revenue Chart ───────────────────────────────────────────────────── -->
    <div class="chart-card">
      <h4><i class="fas fa-chart-area" style="color:var(--primary);"></i> Revenue Trend — Last 12 Orders</h4>
      <canvas id="revenueChart"></canvas>
    </div>

  </div><!-- /content -->
</div><!-- /main -->

<!-- ═══ ORDER HISTORY MODAL ═══════════════════════════════════════════════════ -->
<div class="modal-overlay" id="orderModal">
  <div class="modal-box">
    <div class="modal-title">
      <h3 id="modalUserName"><i class="fas fa-receipt"></i> Order History</h3>
      <button class="close-btn" onclick="closeModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="order-scroll" id="orderScroll">
      <!-- injected by JS -->
    </div>
  </div>
</div>

<script>
  // ── All users & orders data from server ─────────────────────────────────────
  // Passed as JSON so JS can work client-side (search / filter / modal)
  const allUsers  = <%- JSON.stringify(users)  %>;
  const allOrders = <%- JSON.stringify(orders) %>;

  // ── PAGINATION ──────────────────────────────────────────────────────────────
  const ROWS_PER_PAGE = 15;
  let currentPage = 1;
  let visibleRows = [];

  function buildPagination() {
    const totalPages = Math.ceil(visibleRows.length / ROWS_PER_PAGE);
    const wrapper = document.getElementById('paginationWrapper');
    wrapper.innerHTML = '';
    if (totalPages <= 1) return;
    for (let i = 1; i <= totalPages; i++) {
      const btn = document.createElement('button');
      btn.className = 'pg-btn' + (i === currentPage ? ' active' : '');
      btn.textContent = i;
      btn.onclick = () => { currentPage = i; applyPage(); buildPagination(); };
      wrapper.appendChild(btn);
    }
  }

  function applyPage() {
    visibleRows.forEach((row, idx) => {
      const start = (currentPage - 1) * ROWS_PER_PAGE;
      row.style.display = (idx >= start && idx < start + ROWS_PER_PAGE) ? '' : 'none';
    });
  }

  // ── SEARCH / FILTER ─────────────────────────────────────────────────────────
  function applyFilters() {
    const q       = document.getElementById('searchInput').value.toLowerCase();
    const status  = document.getElementById('statusFilter').value;
    const minOrds = parseInt(document.getElementById('orderFilter').value) || 0;
    const rows    = [...document.querySelectorAll('#tableBody tr[data-id]')];
    visibleRows   = [];

    rows.forEach(row => {
      const nameMatch   = row.dataset.name.includes(q) || row.dataset.email.includes(q) || (row.dataset.mobile || '').includes(q);
      const statusMatch = !status || row.dataset.status === status;
      const ordMatch    = parseInt(row.dataset.orders) >= minOrds;
      const show = nameMatch && statusMatch && ordMatch;
      row.style.display = show ? '' : 'none';
      if (show) visibleRows.push(row);
    });

    currentPage = 1;
    applyPage();
    buildPagination();
  }

  document.getElementById('searchInput').addEventListener('input', applyFilters);
  document.getElementById('statusFilter').addEventListener('change', applyFilters);
  document.getElementById('orderFilter').addEventListener('change', applyFilters);

  // Init visible rows on load
  window.addEventListener('DOMContentLoaded', () => {
    visibleRows = [...document.querySelectorAll('#tableBody tr[data-id]')];
    applyPage();
    buildPagination();
    drawChart();
  });

  // ── MODAL – show orders for a user ─────────────────────────────────────────
  function showOrders(userId) {
    const user = allUsers.find(u => u.id == userId);
    if (!user) return;

    document.getElementById('modalUserName').innerHTML =
      `<i class="fas fa-receipt"></i> ${user.name || 'User'} — Orders`;

    const scroll = document.getElementById('orderScroll');
    scroll.innerHTML = '';

    if (!user.orders || user.orders.length === 0) {
      scroll.innerHTML = `<div style="text-align:center; padding:32px; color:var(--muted);">
        <i class="fas fa-inbox" style="font-size:2rem; margin-bottom:8px;"></i><br>No orders yet
      </div>`;
    } else {
      user.orders.forEach(order => {
        const items = order.items || [];
        const card = document.createElement('div');
        card.className = 'order-card';
        card.innerHTML = `
          <div style="display:flex; justify-content:space-between; align-items:flex-start;">
            <div>
              <div class="oid">#${order.uniqueorder_id || order.id}</div>
              <div class="ometa">
                ${new Date(order.created_at).toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'})}
                &nbsp;·&nbsp; ${order.payment_type || 'N/A'}
                &nbsp;·&nbsp; <strong>${order.status || '—'}</strong>
              </div>
            </div>
            <div class="oamt">₹${Number(order.grand_total || 0).toLocaleString('en-IN')}</div>
          </div>
          ${items.length ? `<div class="items-list">
            ${items.map(it => `<span><i class="fas fa-box fa-xs"></i> Product #${it.product_id} &times;${it.quantity} — ₹${Number(it.price).toLocaleString('en-IN')}</span>`).join('')}
          </div>` : ''}
        `;
        scroll.appendChild(card);
      });

      // Total footer
      const total = user.orders.reduce((s, o) => s + parseFloat(o.grand_total || 0), 0);
      const footer = document.createElement('div');
      footer.style.cssText = 'background:#f5f3ff;border-radius:12px;padding:12px 16px;display:flex;justify-content:space-between;font-weight:700;';
      footer.innerHTML = `<span><i class="fas fa-sigma"></i> Total (${user.orders.length} orders)</span><span style="color:var(--primary);">₹${total.toLocaleString('en-IN')}</span>`;
      scroll.appendChild(footer);
    }

    document.getElementById('orderModal').classList.add('open');
  }

  function closeModal() {
    document.getElementById('orderModal').classList.remove('open');
  }
  document.getElementById('orderModal').addEventListener('click', e => {
    if (e.target === e.currentTarget) closeModal();
  });

  // ── BLOCK / UNBLOCK ─────────────────────────────────────────────────────────
  function toggleStatus(userId, newStatus) {
    if (!confirm(`${newStatus === 'blocked' ? 'Block' : 'Unblock'} this user?`)) return;
    fetch('/admin/users/toggle-status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId, status: newStatus })
    })
    .then(r => r.json())
    .then(data => {
      if (data.success) location.reload();
      else alert('Failed: ' + data.error);
    })
    .catch(() => alert('Network error'));
  }

  // ── CHART – revenue from last 12 orders ─────────────────────────────────────
  function drawChart() {
    const last12 = [...allOrders]
      .sort((a, b) => new Date(a.created_at) - new Date(b.created_at))
      .slice(-12);

    const labels = last12.map(o =>
      new Date(o.created_at).toLocaleDateString('en-IN', { day:'2-digit', month:'short' })
    );
    const data = last12.map(o => parseFloat(o.grand_total || 0));

    new Chart(document.getElementById('revenueChart'), {
      type: 'line',
      data: {
        labels: labels.length ? labels : ['No Data'],
        datasets: [{
          label: 'Revenue (₹)',
          data: data.length ? data : [0],
          borderColor: '#4f46e5',
          backgroundColor: 'rgba(79,70,229,0.08)',
          tension: 0.35,
          fill: true,
          pointBackgroundColor: '#818cf8',
          pointRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { position: 'top' },
          tooltip: {
            callbacks: {
              label: ctx => `₹${ctx.raw.toLocaleString('en-IN')}`
            }
          }
        },
        scales: {
          y: {
            ticks: {
              callback: v => `₹${v.toLocaleString('en-IN')}`
            }
          }
        }
      }
    });
  }
</script>
</body>
</html>

<%- include('../../layout/header') %>
<%- include('../../layout/sidebar') %>

<style>
.switch {
  position: relative;
  display: inline-block;
  width: 46px;
  height: 24px;
}

.switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

.slider {
  position: absolute;
  cursor: pointer;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: #ccc;
  transition: .4s;
}

.slider:before {
  position: absolute;
  content: "";
  height: 18px;
  width: 18px;
  left: 3px;
  bottom: 3px;
  background-color: white;
  transition: .4s;
}

input:checked + .slider {
  background-color: #28a745;
}

input:checked + .slider:before {
  transform: translateX(22px);
}

.slider.round {
  border-radius: 24px;
}

.slider.round:before {
  border-radius: 50%;
}
</style>


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<i class="fa-solid fa-pen"></i>
<!--**********************************
            Content body start
        ***********************************-->
        <div class="content-body">
            <!-- row -->

            <div class="container-fluid">
            <%- include('../../brands/type/brands-type-form') %>
                <div class="row">
                    
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-sm-8">
                                        <h4 class="card-title">Brands Type List</h4>
                                    </div>
                                    <div class="col-sm-4">
                                        <%- include('../../utils/searchbox') %>
                                    </div>
                                </div>
                                
                                <div class="table-responsive">
                                    <table id="myTable" class="table table-striped table-bordered zero-configuration">
                                        <thead>
                                            <tr>
                                                <th>Sr. No</th>
                                                <th>Name</th>
                                                <th>Status</th>
                                                <th>Created At</th>
                                                <th>Updated At</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (data && data.length > 0) { %>
                                                <% data.forEach(function(n, index) { %>
                                                    <tr>
                                                        <td><%= ((currentPage - 1) * 10) + index + 1 %></td>
                                                        <td><%= n.name %></td>
                                                        <td>
                                                            <% if (n.status == 1) { %>
                                                                <span class="text-success">Active</span>
                                                            <% } else if (n.status == 2) { %>
                                                                <span class="text-danger">Reject</span>
                                                            <% } else { %>
                                                                <span class="text-primary">Inactive</span>
                                                            <% } %>
                                                        </td>
                                                        <td><%= n.created_at %></td>
                                                        <td><%= n.updated_at %></td>
                                                        <td>
                                                            <i class="fa-solid fa-pen text-primary"></i>
                                                            <i class="fa-solid fa-trash text-danger"></i>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="7" class="text-center">No Data Found</td>
                                                </tr>
                                            <% } %>
                                            </tbody>

                                        <tfoot>
                                            <tr>
                                                <th>Sr. No</th>
                                                <th>Name</th>
                                                <th>Status</th>
                                                <th>Created At</th>
                                                <th>Updated At</th>
                                                <th>Action</th>
                                            </tr>
                                        </tfoot>
                                    </table>
                                    <%- include('../../utils/pagination') %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- #/ container -->
        </div>
        <!--**********************************
            Content body end
        ***********************************-->
        
<script>
function toggleTopBrand(id, status) {
    const value = status ? 1 : 0;

    fetch('/prodsite/brand/top-brand-toggle', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            id: id,
            is_top_brand: value.toString()
        })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            alert(data.message);   // ✅ success msg
        } else {
            alert(data.message || 'Failed to update');
        }
    })
    .catch(err => {
        console.error(err);
        alert('Error occurred');
    });
}
</script>



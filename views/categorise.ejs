<%- include('layout/header', { title: 'Categories List', showNavigation: true }) %>
<%- include('layout/sidebar', { currentPage: 'categories-list' }) %>



<div class="container mt-4">

  <!-- Header -->
  <div class="d-flex justify-content-between mb-3">
    <h3>Category Management</h3>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#categoryModal">
      + Add Category
    </button>
  </div>

  <!-- Tabs -->
  <ul class="nav nav-tabs">
    <li class="nav-item">
      <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#active">
        Active (<span id="activeCount">0</span>)
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#inactive">
        Inactive (<span id="inactiveCount">0</span>)
      </button>
    </li>
  </ul>

  <div class="tab-content mt-3">

    <!-- Active -->
    <div class="tab-pane fade show active" id="active">
      <table class="table table-bordered">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Type</th>
            <th>Date</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="activeList"></tbody>
      </table>
    </div>

    <!-- Inactive -->
    <div class="tab-pane fade" id="inactive">
      <table class="table table-bordered">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Type</th>
            <th>Date</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="inactiveList"></tbody>
      </table>
    </div>

  </div>
</div>

<!-- Modal -->
<div class="modal fade" id="categoryModal">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5>Add Category</h5>
      </div>
      <div class="modal-body">

        <input type="text" id="name" class="form-control mb-2" placeholder="Category Name">

        <select id="type" class="form-control mb-2">
          <option value="1">Normal</option>
          <option value="2">50% OFF</option>
          <option value="3">100% Cashback</option>
        </select>

        <select id="status" class="form-control">
          <option value="1">Active</option>
          <option value="0">Inactive</option>
        </select>

      </div>
      <div class="modal-footer">
        <button class="btn btn-primary" onclick="addCategory()">Save</button>
      </div>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

function loadCategories() {
  $.get('/categories', function(res) {

    let active = res.data.filter(c => c.status == 1);
    let inactive = res.data.filter(c => c.status == 0);

    $('#activeCount').text(active.length);
    $('#inactiveCount').text(inactive.length);

    render(active, '#activeList');
    render(inactive, '#inactiveList');

  });
}

function render(data, selector) {

  if (data.length === 0) {
    $(selector).html('<tr><td colspan="5">No Data</td></tr>');
    return;
  }

  let html = data.map(c => `
    <tr>
      <td>${c.id}</td>
      <td>${c.title}</td>
      <td>
        ${c.type == 1 ? 'Normal' : c.type == 2 ? '50%' : '100%'}
      </td>
      <td>${new Date(c.created_at).toLocaleDateString()}</td>
      <td>
        <button onclick="toggle(${c.id})" class="btn btn-warning btn-sm">Toggle</button>
        <button onclick="deleteCat(${c.id})" class="btn btn-danger btn-sm">Delete</button>
      </td>
    </tr>
  `).join('');

  $(selector).html(html);
}

function addCategory() {
  const data = {
    title: $('#name').val(),
    type: $('#type').val(),
    status: $('#status').val()
  };

  $.post('/add-category', data, function() {
    $('#categoryModal').modal('hide');
    loadCategories();
  });
}

function toggle(id) {
  $.post('/toggle-category', { id }, function() {
    loadCategories();
  });
}

function deleteCat(id) {
  if (confirm("Delete?")) {
    $.post('/delete-category', { id }, function() {
      loadCategories();
    });
  }
}

// init
loadCategories();

</script>



<%- include('layout/footer', { pageScript: 'categories-init.min.js' }) %>
<%- include('../layout/header') %>
<%- include('../layout/sidebar') %>

<style>
.switch { position: relative; display: inline-block; width: 46px; height: 24px; }
.switch input { opacity: 0; width: 0; height: 0; }
.slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #ccc; transition: .4s; }
.slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 3px; bottom: 3px; background-color: white; transition: .4s; }
input:checked + .slider { background-color: #28a745; }
input:checked + .slider:before { transform: translateX(22px); }
.slider.round { border-radius: 24px; }
.slider.round:before { border-radius: 50%; }
.image-preview { max-width: 80px; max-height: 80px; object-fit: cover; border-radius: 6px; }
.type-badge { padding: 4px 8px; border-radius: 20px; font-size: 12px; font-weight: 500; }
.type-normal { background: #6c757d; color: white; }
.type-50 { background: #ffc107; color: #212529; }
.type-100 { background: #dc3545; color: white; }
</style>

<div class="content-body">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-sm-6">
                                <h4 class="card-title">Category Management</h4>
                            </div>
                            <div class="col-sm-6">
                                <div class="input-group">
                                    <input type="text" id="searchInput" class="form-control" placeholder="Search by title..." value="<%= search %>">
                                    <button class="btn btn-primary" id="searchBtn"><i class="fa fa-search"></i></button>
                                </div>
                            </div>
                        </div>

                        <div class="text-end mb-3">
                            <button class="btn btn-success" id="addCategoryBtn"><i class="fa fa-plus"></i> Add Category</button>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-striped table-bordered">
                                <thead>
                                    <tr><th>ID</th><th>Image</th><th>Title</th><th>Type</th><th>Status</th><th>Created</th><th>Actions</th></tr>
                                </thead>
                                <tbody id="categoryTableBody">
                                    <% if (data && data.length > 0) { %>
                                        <% data.forEach(cat => { %>
                                            <tr data-id="<%= cat.id %>">
                                                <td><%= cat.id %></td>
                                                <td><% if(cat.image){ %><img src="<%= cat.image %>" class="image-preview"><% } else { %>—<% } %></td>
                                                <td><%= cat.title %></td>
                                                <td>
                                                    <% if(cat.type == 'normal') { %><span class="type-badge type-normal">Normal</span>
                                                    <% } else if(cat.type == '50%') { %><span class="type-badge type-50">50%</span>
                                                    <% } else if(cat.type == '100%') { %><span class="type-badge type-100">100%</span>
                                                    <% } else { %><%= cat.type %><% } %>
                                                </td>
                                                <td>
                                                    <label class="switch">
                                                        <input type="checkbox" class="status-toggle" data-id="<%= cat.id %>" <%= cat.status == 'active' ? 'checked' : '' %>>
                                                        <span class="slider round"></span>
                                                    </label>
                                                </td>
                                                <td><%= new Date(cat.created_at).toLocaleDateString() %></td>
                                                <td>
                                                    <button class="btn btn-sm btn-primary edit-category" data-id="<%= cat.id %>"><i class="fa fa-edit"></i></button>
                                                    <button class="btn btn-sm btn-danger delete-category" data-id="<%= cat.id %>"><i class="fa fa-trash"></i></button>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="7" class="text-center">No categories found</td></tr>
                                    <% } %>
                                </tbody>
                             </table>
                        </div>

                        <!-- Pagination -->
                        <div class="row">
                            <div class="col-md-12">
                                <nav><ul class="pagination justify-content-center">
                                    <% if (currentPage > 1) { %><li class="page-item"><a class="page-link" href="?page=<%= currentPage-1 %>&search=<%= search %>">Previous</a></li><% } %>
                                    <% for (let i = 1; i <= totalPages; i++) { %>
                                        <li class="page-item <%= i == currentPage ? 'active' : '' %>"><a class="page-link" href="?page=<%= i %>&search=<%= search %>"><%= i %></a></li>
                                    <% } %>
                                    <% if (currentPage < totalPages) { %><li class="page-item"><a class="page-link" href="?page=<%= currentPage+1 %>&search=<%= search %>">Next</a></li><% } %>
                                </ul></nav>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="categoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="categoryForm">
                    <input type="hidden" id="categoryId">
                    <div class="mb-3"><label class="form-label">Title *</label><input type="text" class="form-control" id="title" required></div>
                    <div class="mb-3"><label class="form-label">Image</label><input type="file" class="form-control" id="imageFile" accept="image/*"><input type="hidden" id="existingImage"><div id="imagePreviewContainer" class="mt-2"></div></div>
                    <div class="mb-3"><label class="form-label">Type *</label><select class="form-control" id="type"><option value="normal">Normal</option><option value="50%">50%</option><option value="100%">100%</option></select></div>
                    <div class="mb-3"><label class="form-label">Status</label><select class="form-control" id="status"><option value="active">Active</option><option value="inactive">Inactive</option></select></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveCategoryBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
$(document).ready(function() {
    $('#searchBtn').click(() => window.location.href = '/category/view?page=1&search=' + encodeURIComponent($('#searchInput').val()));
    $('#searchInput').keypress(e => e.which == 13 && $('#searchBtn').click());

    $('#addCategoryBtn').click(() => {
        $('#modalTitle').text('Add Category');
        $('#categoryId').val(''); $('#title').val(''); $('#type').val('normal'); $('#status').val('active');
        $('#existingImage').val(''); $('#imagePreviewContainer').html(''); $('#categoryForm')[0].reset();
        $('#categoryModal').modal('show');
    });

    $(document).on('click', '.edit-category', function() {
        let id = $(this).data('id');
        $.get('/category/get/' + id, function(res) {
            if (res.success) {
                let cat = res.data;
                $('#modalTitle').text('Edit Category');
                $('#categoryId').val(cat.id);
                $('#title').val(cat.title);
                $('#type').val(cat.type);
                $('#status').val(cat.status);
                $('#existingImage').val(cat.image);
                $('#imagePreviewContainer').html(cat.image ? '<img src="'+cat.image+'" class="image-preview">' : '');
                $('#categoryModal').modal('show');
            } else alert('Failed to fetch data');
        });
    });

    $('#saveCategoryBtn').click(function() {
        let id = $('#categoryId').val();
        let title = $('#title').val().trim();
        if (!title) return alert('Title required');
        let formData = new FormData();
        formData.append('title', title);
        formData.append('type', $('#type').val());
        formData.append('status', $('#status').val());
        if (id) formData.append('id', id);
        let file = $('#imageFile')[0].files[0];
        if (file) formData.append('image', file);
        else if ($('#existingImage').val()) formData.append('existing_image', $('#existingImage').val());

        let url = id ? '/category/update' : '/category/add';
        $.ajax({ url, type: 'POST', data: formData, processData: false, contentType: false,
            success: res => { if(res.success){ alert(res.message); location.reload(); } else alert(res.message); },
            error: () => alert('Server error')
        });
    });

    $(document).on('click', '.delete-category', function() {
        if (!confirm('Delete this category?')) return;
        let id = $(this).data('id');
        $.post('/category/delete', { id }, res => { if(res.success){ alert('Deleted'); location.reload(); } else alert(res.message); });
    });

    $(document).on('change', '.status-toggle', function() {
        let id = $(this).data('id');
        let status = $(this).is(':checked') ? 'active' : 'inactive';
        $.post('/category/toggle-status', { id, status }, res => { if(!res.success) location.reload(); });
    });
});
</script>

<%- include('../layout/footer') %>
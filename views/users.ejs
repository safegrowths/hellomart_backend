<%- include('../layout/header', { title: 'Users List' }) %>
<%- include('../layout/sidebar', { currentPage: 'users' }) %>

<div class="content-body">
    <div class="container-fluid">

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">

                        <div class="row align-items-center mb-3">
                            <div class="col-sm-8">
                                <h4 class="card-title mb-0">Users List</h4>
                            </div>
                            <div class="col-sm-4">
                                <%- include('../utils/searchbox', { 
                                    search: search || '', 
                                    action: '/users/view' 
                                }) %>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-striped table-bordered">
                                <thead class="table-dark">
                                    <tr>
                                        <th>#</th>
                                        <th>Name</th>
                                        <th>Mobile</th>
                                        <th>Email</th>
                                        <th>Image</th>
                                        <th>Created At</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <% if (users && users.length > 0) { %>
                                        <% users.forEach((u, index) => { %>
                                            <tr>
                                                <td><%= ((currentPage - 1) * limit) + index + 1 %></td>

                                                <td><%= u.name %></td>
                                                <td><%= u.mobile || '-' %></td>
                                                <td><%= u.email %></td>

                                                <td>
                                                    <img src="<%= u.image || 'https://placehold.co/50x50?text=No+Image' %>"
                                                         height="50" width="50"
                                                         style="border-radius:50%; object-fit:cover;">
                                                </td>

                                                <td>
                                                    <%= u.created_at ? new Date(u.created_at).toLocaleString() : '-' %>
                                                </td>

                                                <td>
                                                    <button class="btn btn-sm btn-outline-primary me-1"
                                                        onclick="editUser(<%= u.id %>)">
                                                        <i class="fas fa-pen"></i>
                                                    </button>

                                                    <button class="btn btn-sm btn-outline-danger"
                                                        onclick="deleteUser(<%= u.id %>)">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="text-center text-muted">No users found</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>

                            <%- include('../utils/pagination', { 
                                currentPage: currentPage, 
                                totalPages: totalPages, 
                                search: search, 
                                baseUrl: '/users/view' 
                            }) %>
                        </div>

                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<%- include('../layout/footer') %>

<script>
function editUser(id) {
    window.location.href = `/users/edit/${id}`;
}

async function deleteUser(id) {
    if (!confirm('Delete this user?')) return;

    try {
        const res = await fetch(`/users/delete/${id}`, { method: 'DELETE' });
        const data = await res.json();

        if (data.success) {
            location.reload();
        } else {
            alert(data.message || 'Delete failed');
        }
    } catch (err) {
        alert(err.message);
    }
}
</script>
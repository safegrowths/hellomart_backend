<style>
#searchForm input {
    border-radius: 4px 0 0 4px;
    border-right: none;
}

#searchForm button {
    border-radius: 0 4px 4px 0;
}

#exportDropdown {
    border-radius: 4px;
}

.btn-outline-primary {
    border: 1px solid #0d6efd !important;
    color: #0d6efd !important;
    background: transparent !important;
}

.btn-outline-primary:hover {
    background: #0d6efd !important;
    color: #fff !important;
}
</style>


<div class="d-flex align-items-center mb-3" style="gap: 10px;">
    <!-- Search Form -->
    <form class="d-flex" id="searchForm">
        <input type="text" class="form-control" placeholder="Search by <%= pageName %> Name" name="search" value="<%= search %>">
        <button type="button" class="btn btn-info" id="searchButton">Search</button>
    </form>

    <!-- Export Button -->
    <div class="dropdown">
        <button class="btn btn-outline-primary dropdown-toggle" type="button" id="exportDropdown" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            Export
        </button>
        <div class="dropdown-menu" aria-labelledby="exportDropdown">
            <a class="dropdown-item" href="#">Export CSV</a>
            <a class="dropdown-item" href="#">Export Excel</a>
            <a class="dropdown-item" href="#">Export PDF</a>
        </div>
    </div>
</div>
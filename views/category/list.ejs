<%- include('../layout/header', { title: 'Category List' }) %>
<%- include('../layout/sidebar', { currentPage: 'categories' }) %>

<!-- Content body start -->
<div class="content-body">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row align-items-center mb-3">
                            <div class="col-sm-8">
                                <!-- Add Category Button - now on left side -->
                                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
                                    <i class="fas fa-plus"></i> Add Category
                                </button>
                            </div>
                            <div class="col-sm-4">
                                <%- include('../utils/searchbox', { 
                                    search: search || '', 
                                    action: '/category_view' 
                                }) %>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-striped table-bordered">
                                <thead class="table-dark">
                                    <tr>
                                        <th>#</th>
                                        <th>Name</th>
                                        <th>Image</th>
                                        <th>Type</th>
                                        <th>Status</th>
                                        <th>Created At</th>
                                        <th>Updated At</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody id="categoryTableBody">
                                    <% if (categories && categories.length > 0) { %>
                                        <% categories.forEach((cat, index) => { %>
                                            <tr data-id="<%= cat.id %>">
                                                <td><%= ((currentPage - 1) * 10) + index + 1 %></td>
                                                <td class="cat-name"><%= cat.name %></td>
                                                <td class="cat-image">
                                                    <img src="<%= cat.image %>" 
                                                         class="clickable-image"
                                                         height="50" width="50" 
                                                         onerror="this.src='https://placehold.co/50x50?text=No+Image'"
                                                         style="border-radius: 50%; object-fit: cover; cursor: pointer;">
                                                </td>
                                                <td class="cat-type">
                                                    <% if (cat.type == 1) { %> Normal
                                                    <% } else if (cat.type == 2) { %> 50%
                                                    <% } else if (cat.type == 3) { %> 100%
                                                    <% } else { %> - <% } %>
                                                </td>
                                                <td class="cat-status">
                                                    <% if (cat.status == 1) { %>
                                                        <span class="badge bg-success">Active</span>
                                                    <% } else if (cat.status == 2) { %>
                                                        <span class="badge bg-danger">Reject</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary">Inactive</span>
                                                    <% } %>
                                                </td>
                                                <td><%= cat.created_at || '-' %></td>
                                                <td><%= cat.updated_at || '-' %></td>
                                                <td>
                                                    <button class="btn btn-sm btn-outline-primary me-1 edit-category-btn" 
                                                            data-id="<%= cat.id %>"
                                                            data-name="<%= cat.name %>"
                                                            data-image="<%= cat.image %>"
                                                            data-status="<%= cat.status %>"
                                                            data-type="<%= cat.type %>">
                                                        <i class="fas fa-pen"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger delete-category-btn" 
                                                            data-id="<%= cat.id %>">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="8" class="text-center text-muted">No categories found</td></tr>
                                    <% } %>
                                </tbody>
                            </table>

                            <%- include('../utils/pagination', { 
                                currentPage: currentPage, 
                                totalPages: totalPages, 
                                search: search, 
                                baseUrl: '/category_view' 
                            }) %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ADD CATEGORY MODAL (with file upload) -->
<div class="modal fade" id="addCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addCategoryForm" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label>Name *</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label>Image (Upload)</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*">
                        <small class="text-muted">Supported: jpg, png, gif, webp (max 5MB)</small>
                        <div id="imagePreviewAdd" class="mt-2" style="display:none;">
                            <img id="previewAddImg" src="#" height="80" style="border-radius: 8px;">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label>Type</label>
                        <select name="type" class="form-control">
                            <option value="1">Normal</option>
                            <option value="2">50%</option>
                            <option value="3">100%</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label>Status</label>
                        <select name="status" class="form-control">
                            <option value="1">Active</option>
                            <option value="0">Inactive</option>
                            <option value="2">Reject</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveCategoryBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- EDIT CATEGORY MODAL -->
<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editCategoryForm">
                    <input type="hidden" name="id" id="editCatId">
                    <div class="mb-3">
                        <label>Name *</label>
                        <input type="text" name="name" id="editCatName" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label>Current Image</label><br>
                        <img id="currentCatImage" src="" height="60" style="border-radius: 8px;">
                        <label class="mt-2">Change Image (optional)</label>
                        <input type="file" name="imageFile" id="editCatImageFile" class="form-control" accept="image/*">
                        <div id="imagePreviewEdit" class="mt-2" style="display:none;">
                            <img id="previewEditImg" src="#" height="80" style="border-radius: 8px;">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label>Type</label>
                        <select name="type" id="editCatType" class="form-control">
                            <option value="1">Normal</option>
                            <option value="2">50%</option>
                            <option value="3">100%</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label>Status</label>
                        <select name="status" id="editCatStatus" class="form-control">
                            <option value="1">Active</option>
                            <option value="0">Inactive</option>
                            <option value="2">Reject</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="updateCategoryBtn">Update</button>
            </div>
        </div>
    </div>
</div>

<!-- IMAGE PREVIEW MODAL (enlarged) -->
<div class="modal fade" id="imagePreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Category Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <img id="previewImage" src="" alt="Category Image" style="max-width: 100%; max-height: 70vh;">
            </div>
        </div>
    </div>
</div>

<%- include('../layout/footer') %>

<!-- Font Awesome fallback -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<script>
    // Helper to reload current page (preserve search & pagination)
    function reloadPage() {
        const url = new URL(window.location.href);
        window.location.href = url.pathname + url.search;
    }

    // Preview image before upload (Add modal)
    const addImageInput = document.querySelector('#addCategoryForm input[name="imageFile"]');
    if (addImageInput) {
        addImageInput.addEventListener('change', function(e) {
            const previewDiv = document.getElementById('imagePreviewAdd');
            const previewImg = document.getElementById('previewAddImg');
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = function(ev) {
                    previewImg.src = ev.target.result;
                    previewDiv.style.display = 'block';
                };
                reader.readAsDataURL(this.files[0]);
            } else {
                previewDiv.style.display = 'none';
            }
        });
    }

    // ADD category (with file upload)
    const saveBtn = document.getElementById('saveCategoryBtn');
    if (saveBtn) {
        saveBtn.addEventListener('click', async () => {
            const form = document.getElementById('addCategoryForm');
            const formData = new FormData(form);

            try {
                const res = await fetch('/category_add', {
                    method: 'POST',
                    body: formData   // no Content-Type header, browser sets it with boundary
                });
                const result = await res.json();
                if (result.success) {
                    const modal = bootstrap.Modal.getInstance(document.getElementById('addCategoryModal'));
                    modal.hide();
                    form.reset();
                    document.getElementById('imagePreviewAdd').style.display = 'none';
                    reloadPage();
                } else {
                    alert(result.message || 'Add failed');
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        });
    }

    // EDIT - populate modal
    document.querySelectorAll('.edit-category-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name');
            const image = btn.getAttribute('data-image');
            const status = btn.getAttribute('data-status');
            const type = btn.getAttribute('data-type');

            document.getElementById('editCatId').value = id;
            document.getElementById('editCatName').value = name;
            document.getElementById('editCatStatus').value = status;
            document.getElementById('editCatType').value = type;
            document.getElementById('currentCatImage').src = image || 'https://placehold.co/80x80?text=No+Image';
            document.getElementById('editCatImageFile').value = '';
            document.getElementById('imagePreviewEdit').style.display = 'none';

            new bootstrap.Modal(document.getElementById('editCategoryModal')).show();
        });
    });

    // Preview new image in Edit modal
    const editImageInput = document.getElementById('editCatImageFile');
    if (editImageInput) {
        editImageInput.addEventListener('change', function() {
            const previewDiv = document.getElementById('imagePreviewEdit');
            const previewImg = document.getElementById('previewEditImg');
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = function(ev) {
                    previewImg.src = ev.target.result;
                    previewDiv.style.display = 'block';
                };
                reader.readAsDataURL(this.files[0]);
            } else {
                previewDiv.style.display = 'none';
            }
        });
    }

    // UPDATE category (with optional file)
    const updateBtn = document.getElementById('updateCategoryBtn');
    if (updateBtn) {
        updateBtn.addEventListener('click', async () => {
            const id = document.getElementById('editCatId').value;
            const formData = new FormData();
            formData.append('name', document.getElementById('editCatName').value);
            formData.append('status', document.getElementById('editCatStatus').value);
            formData.append('type', document.getElementById('editCatType').value);
            const fileInput = document.getElementById('editCatImageFile');
            if (fileInput.files.length > 0) {
                formData.append('imageFile', fileInput.files[0]);
            }

            try {
                const res = await fetch(`/category_edit/${id}`, {
                    method: 'POST',   // using POST because PUT with FormData can be tricky; we'll handle in route
                    body: formData
                });
                const result = await res.json();
                if (result.success) {
                    const modal = bootstrap.Modal.getInstance(document.getElementById('editCategoryModal'));
                    modal.hide();
                    reloadPage();
                } else {
                    alert(result.message || 'Update failed');
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        });
    }

    // DELETE category
    document.querySelectorAll('.delete-category-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            if (!confirm('Are you sure you want to delete this category?')) return;
            const id = btn.getAttribute('data-id');
            try {
                const res = await fetch(`/category_delete/${id}`, { method: 'DELETE' });
                const result = await res.json();
                if (result.success) {
                    reloadPage();
                } else {
                    alert(result.message || 'Delete failed');
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        });
    });

    // IMAGE PREVIEW ON CLICK (enlarge)
    document.querySelectorAll('.clickable-image').forEach(img => {
        img.addEventListener('click', (e) => {
            e.stopPropagation();
            const src = img.getAttribute('src');
            if (src && src !== 'https://placehold.co/50x50?text=No+Image') {
                document.getElementById('previewImage').src = src;
                new bootstrap.Modal(document.getElementById('imagePreviewModal')).show();
            }
        });
    });
</script>

<style>
    .content-body {
        margin-left: 260px;
        padding: 20px;
        transition: all 0.3s;
    }
    @media (max-width: 768px) {
        .content-body {
            margin-left: 0;
        }
    }
    .table img {
        max-width: 50px;
        max-height: 50px;
        object-fit: cover;
    }
    .clickable-image {
        cursor: pointer;
        transition: transform 0.2s;
    }
    .clickable-image:hover {
        transform: scale(1.1);
    }
    .btn-primary {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }
    .btn-primary:hover {
        background-color: #0b5ed7;
    }
</style>
<%- include('../layout/sidebar') %>
    <%- include('../layout/header') %>
        <main class="nxl-container">
            <div class="nxl-content">
                <!-- page-header -->
                <div class="page-header">
                    <div class="page-header-left d-flex align-items-center">
                        <div class="page-header-title">
                            <h5 class="m-b-10"><%= pageName %></h5>
                        </div>
                        <ul class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">Home</a></li>
                            <li class="breadcrumb-item"><%= pageName %></li>
                        </ul>
                    </div>
                </div>

                <div class="main-content">
                    <div class="row">
                        <div class="col-lg-12">
                            <div class="card">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-sm-8">
                                        <h4 class="card-title"><%= pageName %> List</h4>
                                    </div>
                                    <div class="col-sm-4">
                                        <%- include('../utils/searchbox') %>
                                    </div>
                                </div>
                                
                                <div class="table-responsive">
                                    <table id="myTable" class="table table-striped table-bordered zero-configuration">
                                        <thead>
                                            <tr>
                                                <th>Sr. No</th>
                                                <th>Order Unique Id</th>
                                                <th>User Name</th>
                                                <th>Total Order Item</th>
                                                <th>Bag MRP</th>
                                                <th>Bag Discount</th>
                                                <th>Grand Total</th>
                                                <th>Payment Type</th>
                                                <th>Order Status</th>
                                                <th>Created At</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (data && data.length > 0) { %>
                                                <% data.forEach(function(n, index) { %>
                                                    <tr>
                                                        <td><%= ((currentPage - 1) * 10) + index + 1 %></td>
                                                        <td><%= n.uniqueorder_id %></td>
                                                        <td><%= n.userdata %> (<%= n.username %>)</td>
                                                        <td><a href=""><%= n.TotalOrderItem %></a></td>
                                                        <td><%= n.bag_mrp %></td>
                                                        <td><%= n.bag_discount %></td>
                                                        <td><%= n.grand_total %></td>
                                                        <td><%= n.payment_type %></td>
                                                        <td><%= n.status %></td>
                                                        <td><%= n.created_at %></td>
                                                        <td>
                                                            <i class="fa-solid fa-pen text-primary"></i>
                                                            <i class="fa-solid fa-trash text-danger"></i>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="11" class="text-center">No Data Found</td>
                                                </tr>
                                            <% } %>
                                            </tbody>

                                        <tfoot>
                                            <tr>
                                                <th>Sr. No</th>
                                                <th>Order Unique Id</th>
                                                <th>User Name</th>
                                                <th>Total Order Item</th>
                                                <th>Bag MRP</th>
                                                <th>Bag Discount</th>
                                                <th>Grand Total</th>
                                                <th>Payment Type</th>
                                                <th>Order Status</th>
                                                <th>Created At</th>
                                                <th>Action</th>
                                            </tr>
                                        </tfoot>
                                    </table>
                                    <%- include('../utils/pagination') %>
                                </div>
                            </div>
                        </div>
                        </div>
                    </div>
                </div>
                <!-- [ Main Content ] end -->


            <!--**********************************
            Content body end
        ***********************************-->

            <script>
                function toggleTopBrand(id, status) {
                    const value = status ? 1 : 0;

                    fetch('/prodsite/brand/top-brand-toggle', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            id: id,
                            is_top_brand: value.toString()
                        })
                    })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                alert(data.message);   // ✅ success msg
                            } else {
                                alert(data.message || 'Failed to update');
                            }
                        })
                        .catch(err => {
                            console.error(err);
                            alert('Error occurred');
                        });
                }
            </script>


            <%- include('../layout/footer' , { pageScript: 'dashboard-init.min.js' }) %>